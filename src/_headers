# Cloudflare Pages headers
# Processed by Cloudflare Pages at deploy time — not served as a file.
# Rules are matched top-to-bottom; first match wins.
# Docs: https://developers.cloudflare.com/pages/configuration/headers/

# ── Security headers (applied to all pages) ──────────────────────────────────
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' https://cdn.jsdelivr.net https://giscus.app; worker-src blob:; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; img-src 'self' https://tiles.dustin.space https://cdn.astrobin.com https://cdn.jsdelivr.net https://aladin.cds.unistra.fr data: blob:; font-src 'self'; connect-src 'self' https://tiles.dustin.space https://alasky.cds.unistra.fr https://alaskybis.cds.unistra.fr https://alasky.unistra.fr https://alaskybis.unistra.fr https://simbad.cds.unistra.fr; frame-src https://giscus.app; object-src 'none'; base-uri 'self'; form-action 'self' https://api.web3forms.com

# Fonts — immutable: content-addressed filenames (woff2 files won't change
# unless the actual font bytes change, at which point the filename changes).
/assets/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Images — long cache, but not immutable (hero/thumbnails may be replaced
# in place without a filename change during early development).
/assets/img/*
  Cache-Control: public, max-age=86400

# Tile pyramids served locally (dev only — production tiles are on R2).
/tiles/*
  Cache-Control: public, max-age=86400

# CSS and JS — short cache since filenames are not content-hashed.
# Increase this after adding content-hash suffixes to filenames.
/assets/css/*
  Cache-Control: public, max-age=3600

/assets/js/*
  Cache-Control: public, max-age=3600
