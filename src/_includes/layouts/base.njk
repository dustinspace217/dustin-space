<!DOCTYPE html>
{#
	Base layout — every page on the site inherits from this template.
	In 11ty + Nunjucks, child templates specify `layout: layouts/base.njk`
	in their front matter, and then their body is injected at {{ content | safe }}.
	The `| safe` filter tells Nunjucks not to escape the HTML.
#}
<html lang="en">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />

	<!--
		`title` comes from each page's front matter.
		`site` is the global data object loaded from src/_data/site.json —
		11ty automatically makes all _data files available as template variables.
	-->
	<title>{% if title %}{{ title }} | {% endif %}{{ site.title }}</title>

	<!-- Open Graph tags for social sharing previews -->
	<meta property="og:site_name" content="{{ site.title }}" />
	<meta property="og:title" content="{% if title %}{{ title }}{% else %}{{ site.title }}{% endif %}" />
	<meta property="og:description" content="{% if description %}{{ description }}{% else %}{{ site.description }}{% endif %}" />
	{% if ogImage %}
	<meta property="og:image" content="{{ site.url }}{{ ogImage }}" />
	{% endif %}

	<!--
		Self-hosted fonts: Space Grotesk (headings), Inter (body), Corinthia (brand script).
		Latin subset only — no Google Fonts CDN request, no GDPR exposure.
		Font files live in /assets/fonts/ alongside this CSS.
	-->
	<link rel="stylesheet" href="/assets/fonts/fonts.css" />

	<link rel="stylesheet" href="/assets/css/main.css" />
</head>
<body class="{{ bodyClass }}">

	{% include "partials/header.njk" %}

	<!--
		`content` is the rendered output of the child template —
		whatever page is using this layout fills this slot.
	-->
	<main>
		{{ content | safe }}
	</main>

	{% include "partials/footer.njk" %}

	<!--
		gallery.js handles the filter buttons on the gallery page.
		It exits early if no filter buttons exist, but we only load it
		on pages that actually have a gallery to keep other pages lean.
		`galleryPage: true` is set in the front matter of gallery/index.njk.
	-->
	{% if galleryPage %}
	<script src="/assets/js/gallery.js"></script>
	{% endif %}

	<!--
		Mobile nav toggle — wires the hamburger button to open/close the nav.
		Uses aria-expanded on the button so screen readers announce the state.
	-->
	<script>
	(function () {
		var btn    = document.getElementById('nav-toggle-btn');
		var header = document.getElementById('site-header');
		if (!btn || !header) return;

		btn.addEventListener('click', function () {
			// Flip the open state
			var isOpen = btn.getAttribute('aria-expanded') === 'true';
			btn.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
			header.classList.toggle('nav-open', !isOpen);
		});

		// Close the nav when the user clicks anywhere outside the header
		document.addEventListener('click', function (e) {
			if (!header.contains(e.target)) {
				btn.setAttribute('aria-expanded', 'false');
				header.classList.remove('nav-open');
			}
		});
	}());
	</script>
</body>
</html>
