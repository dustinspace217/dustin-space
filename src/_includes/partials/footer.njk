<!--
	Site footer — appears on every page via the base layout.
	`site` comes from src/_data/site.json.
-->
<footer class="site-footer">
	<div class="footer-inner">

		<!-- DK Astrophotography secondary brand — script/signature style -->
		<div class="footer-brand">
			<span class="footer-dk">DK Astrophotography</span>
		</div>

		<nav class="footer-nav" aria-label="Footer navigation">
			<a href="/gallery/">Gallery</a>
			<a href="/setup/">My Setup</a>
			<a href="/guides/">Guides</a>
			<a href="/about/">About</a>
			<a href="/store/">Store</a>
			<a href="/contact/">Contact</a>
			<a href="https://github.com/dustinspace217/dustin-space" target="_blank" rel="noopener noreferrer" aria-label="Source code on GitHub">GitHub</a>
		</nav>

		<p class="footer-copy">
			&copy; {{ year }} {{ site.author }} &mdash; All images are original works. Reproduction requires written permission.
		</p>

		<!--
			Colophon — credits the tools that built the site.
			Links open in new tabs; rel="noopener noreferrer" is standard practice
			for external links to prevent tab-napping and referrer leakage.
		-->
		<p class="footer-colophon">
			Built with
			<a href="https://www.11ty.dev" target="_blank" rel="noopener noreferrer">Eleventy</a>
			&middot;
			<a href="https://pages.cloudflare.com" target="_blank" rel="noopener noreferrer">Cloudflare Pages</a>
			&middot;
			<a href="https://www.cloudflare.com/products/r2/" target="_blank" rel="noopener noreferrer">R2</a>
			&middot;
			<a href="https://openseadragon.github.io" target="_blank" rel="noopener noreferrer">OpenSeadragon</a>
			&middot;
			<a href="https://aladin.cds.unistra.fr/AladinLite/" target="_blank" rel="noopener noreferrer">Aladin Lite</a>
			&middot;
			<a href="https://giscus.app" target="_blank" rel="noopener noreferrer">Giscus</a>
		</p>

	</div>
</footer>
