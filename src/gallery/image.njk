---
pagination:
  data: images
  size: 1
  alias: image
permalink: "gallery/{{ image.slug }}/"
layout: "layouts/base.njk"
---

{#
	JSON-LD structured data — injected into <head> via the layout's {% block head %}.
	schema.org/ImageObject tells Google the image's title, description, creator, date,
	and canonical URL. This enables rich results in Google Images (name, date, author
	shown beneath the thumbnail) without any visible change to the page.

	| dump serialises Nunjucks values to JSON-safe strings — handles quotes,
	newlines, and special characters so the inline JSON stays valid.
#}
{% set heroSrcForLD = image.preview_url or image.full_url or image.thumbnail %}
{% block head %}
<script type="application/ld+json">
{
	"@context": "https://schema.org",
	"@type": "ImageObject",
	"name": {{ image.title | dump | safe }},
	"description": {{ (image.description or "") | dump | safe }},
	"contentUrl": {{ (heroSrcForLD or "") | dump | safe }},
	"thumbnailUrl": {{ (image.thumbnail or "") | dump | safe }},
	"datePublished": {{ image.date | dump | safe }},
	"url": "{{ site.url }}/gallery/{{ image.slug }}/",
	"author": {
		"@type": "Person",
		"name": {{ site.author | dump | safe }}
	},
	"creator": {
		"@type": "Person",
		"name": {{ site.author | dump | safe }}
	},
	"keywords": {{ (image.tags | join(", ")) | dump | safe }}
}
</script>
{% endblock %}

<!--
	IMAGE DETAIL PAGE
	`image` is the aliased pagination item — the single image object from images.json.

	HERO DISPLAY — three-tier fallback:
	  1. dzi_url is set  → thumbnail preview on the page; fullscreen OSD lightbox on click
	  2. full_url is set → plain <img> tag (transitional, while tiling is in progress)
	  3. neither        → placeholder div

	LIGHTBOX (dzi_url path only):
	  Clicking the thumbnail opens a full-viewport lightbox. OSD is initialized
	  lazily — it doesn't load until the first click. The lightbox covers 100vw×100vh
	  so OSD has no height constraint and the entire image is visible. Body scroll
	  is locked while the lightbox is open. Escape key or the Close button dismisses it.

	ANNOTATION TOGGLE:
	  Deep zoom mode:  swaps tile source via viewer.open(annotated_dzi_url)
	  Fallback mode:   swaps <img> src between full_url and annotated_url
-->

{# Aladin Lite v3 injects its CSS dynamically — no separate link tag needed. #}

<article class="image-detail">

	<!-- ─────────────────────────────────────────────────────
	     HERO — Zoom trigger OR Fallback Image
	──────────────────────────────────────────────────────── -->
	<div class="image-hero-wrap">

		<!--
			Back link — frosted chip in the top-left corner of the hero,
			always visible over the image. Uses history.back() when the visitor
			came from the gallery so any active filter (?filter=messier) is
			preserved in the URL.
		-->
		<a href="/gallery/" class="hero-back-link" id="back-link">← Gallery</a>
		<script>
			(function () {
				var ref = document.referrer;
				if (ref && ref.includes(location.host) && ref.includes('/gallery/')) {
					document.getElementById('back-link').addEventListener('click', function (e) {
						e.preventDefault();
						history.back();
					});
				}
			}());
		</script>

		{% if image.dzi_url %}
			<!--
				Zoom trigger — a thumbnail preview of the image.
				Clicking opens the full-viewport lightbox with the OSD deep zoom viewer.
				The button element makes it keyboard-accessible without extra ARIA work.
			-->
			<button
				class="zoom-trigger"
				id="zoom-trigger"
				aria-label="Open {{ image.title }} in full-resolution viewer"
				aria-haspopup="dialog"
			>
				{#
					Preview priority:
					  1. preview_url  — medium-res (~2400px) hosted on R2, best quality
					  2. full_url     — local full-resolution image
					  3. thumbnail    — AstroBin 620px fallback; add preview_url to fix pixelation
				#}
				{% set heroSrc = image.preview_url or image.full_url or image.thumbnail %}
				{% if heroSrc %}
					<img
						src="{{ heroSrc }}"
						alt="{{ image.title }}"
						class="zoom-trigger-img"
					/>
				{% else %}
					<div class="image-hero image-hero--placeholder" aria-hidden="true">✦</div>
				{% endif %}

				<!-- Floating hint at the bottom of the preview -->
				<span class="zoom-trigger-hint" aria-hidden="true">&#x2315; Explore full resolution</span>
			</button>

		{% elif image.full_url %}
			<!--
				Fallback: plain image while tile pyramid is being prepared.
				Supports the existing annotated_url swap if present.
			-->
			<img
				id="hero-img"
				class="image-hero"
				src="{{ image.full_url }}"
				alt="{{ image.title }}"
				data-clean="{{ image.full_url }}"
				data-annotated="{{ image.annotated_url or '' }}"
			/>

			{% if image.annotated_url %}
				<button id="annotate-toggle" class="annotate-btn" aria-pressed="false">
					Show Annotations
				</button>
			{% endif %}

		{% else %}
			<div class="image-hero image-hero--placeholder" aria-hidden="true">✦</div>
		{% endif %}

	</div><!-- /.image-hero-wrap -->


	<div class="image-detail-body">

		<!-- ─────────────────────────────────────────
		     TITLE + CATALOG + DATE
		──────────────────────────────────────────── -->
		<div class="image-detail-header">
			<h1>{{ image.title }}</h1>
			<div class="image-catalog">{{ image.catalog }}</div>
			<div class="image-date">
				{{ image.date | readableDate }}
				{% if image.equipment %} &mdash; {{ image.equipment.location }}{% endif %}
			</div>
			<!--
				AstroBin deep link — only rendered when astrobin_id is set in images.json.
				Opens in a new tab so the visitor stays on the detail page.
				rel="noopener noreferrer" prevents the opened tab from accessing
				window.opener and avoids leaking the referrer URL.
			-->
			{% if image.astrobin_id %}
			<a
				href="https://www.astrobin.com/{{ image.astrobin_id }}/"
				class="astrobin-link"
				target="_blank"
				rel="noopener noreferrer"
			>View on AstroBin ↗</a>
			{% endif %}
		</div>

		<!-- ─────────────────────────────────────────
		     TWO-COLUMN INFO GRID
		     Left: acquisition + equipment tables
		     Right: sky atlas widget
		──────────────────────────────────────────── -->
		<div class="image-info-grid">

			<!-- LEFT: metadata -->
			<div class="image-meta-column">

				<!-- Per-filter exposure breakdown -->
				{% if image.acquisition and image.acquisition.filters %}
				<h3>Acquisition</h3>

				{% if image.acquisition.mode == "lucky" %}
					<p class="acq-note">{{ image.acquisition.note }}</p>
				{% endif %}

				<table class="metadata-table" aria-label="Per-filter exposure breakdown">
					<thead>
						<tr>
							<th scope="col">Filter</th>
							<th scope="col">Frames</th>
							<th scope="col">Time</th>
						</tr>
					</thead>
					<tbody>
						{% for f in image.acquisition.filters %}
						<tr>
							<td>{{ f.name }}</td>
							<td>{{ f.frames }}</td>
							<td>{% if f.minutes %}{{ f.minutes | formatExposure }}{% else %}—{% endif %}</td>
						</tr>
						{% endfor %}
					</tbody>
					{% if image.acquisition.filters | length > 1 %}
					<tfoot>
						<tr class="acq-total">
							<th scope="row" colspan="2">Total</th>
							<td>{{ image.acquisition.filters | formatExposure }}</td>
						</tr>
					</tfoot>
					{% endif %}
				</table>
				{% endif %}

				<!-- Per-image equipment -->
				{% if image.equipment %}
				<h3>Equipment</h3>
				<table class="metadata-table" aria-label="Image acquisition equipment">
					<tbody>
						<tr><th scope="row">Telescope</th><td>{{ image.equipment.telescope }}</td></tr>
						<tr><th scope="row">Camera</th>   <td>{{ image.equipment.camera }}</td></tr>
						<tr><th scope="row">Mount</th>    <td>{{ image.equipment.mount }}</td></tr>
						<tr><th scope="row">Guiding</th>  <td>{{ image.equipment.guider }}</td></tr>
						<tr><th scope="row">Filters</th>  <td>{{ image.equipment.filters }}</td></tr>
						<tr><th scope="row">Software</th> <td>{{ image.equipment.software }}</td></tr>
					</tbody>
				</table>
				{% endif %}

			</div><!-- /.image-meta-column -->

			<!-- RIGHT: Aladin Lite sky atlas -->
			<div class="aladin-panel">
				<h3>Sky Position</h3>

				{% if image.sky and image.sky.aladin_target %}
					<div id="aladin-lite-div"></div>
					<!--
						Aladin Lite v3 loaded from jsDelivr (CORS-enabled).
						IntersectionObserver defers initialization until the widget is
						near the viewport. Dynamic import() catches init failures.
						| dump JSON-serializes strings, preventing JS injection.
					-->
					<script type="module">
						(function () {
							var el = document.getElementById('aladin-lite-div');
							if (!el) return;

							var observer = new IntersectionObserver(function (entries, obs) {
								if (!entries[0].isIntersecting) return;
								obs.disconnect();

								(async function () {
									try {
										const { default: A } = await import('https://cdn.jsdelivr.net/npm/aladin-lite@3.8.2/dist/aladin.js');

										// Store the returned instance so we can call overlay methods.
										const aladin = await A.aladin('#aladin-lite-div', {
											survey: 'P/DSS2/color',
											fov: {{ image.sky.fov_deg or 1.5 }},
											target: {{ image.sky.aladin_target | dump | safe }},
											showReticle: false,
											showZoomControl: true,
											showFullscreenControl: false,
											showLayersControl: false,
											showGotoControl: false,
										});

										{#
											FOV rectangle — drawn when ra_deg/dec_deg/fov_w/fov_h are all present.
											Shows the camera's actual field of view as a cyan rectangle on the sky atlas.
											RA offset is divided by cos(dec) so the box stays rectangular at high Dec.
										#}
										{% if image.sky.fov_w and image.sky.fov_h
										   and image.sky.ra_deg is not none
										   and image.sky.dec_deg is not none %}
										(function () {
											var raDeg  = {{ image.sky.ra_deg }};
											var decDeg = {{ image.sky.dec_deg }};
											var hw     = {{ image.sky.fov_w }} / 2;
											var hh     = {{ image.sky.fov_h }} / 2;
											var cosDec = Math.cos(decDeg * Math.PI / 180);
											var dRa    = hw / cosDec;

											var corners = [
												[raDeg + dRa, decDeg + hh],
												[raDeg - dRa, decDeg + hh],
												[raDeg - dRa, decDeg - hh],
												[raDeg + dRa, decDeg - hh],
											];

											var overlay = A.graphicOverlay({
												color:     'rgba(100, 210, 220, 0.7)',
												lineWidth: 1.5,
											});
											aladin.addOverlay(overlay);
											overlay.add(A.polygon(corners));
										})();
										{% endif %}

									} catch (e) {
										el.innerHTML = '<div class="aladin-na">Sky atlas unavailable.</div>';
									}
								})();
							}, { rootMargin: '300px' });

							observer.observe(el);
						})();
					</script>
				{% else %}
					<div class="aladin-na">
						Sky atlas not available for solar images.
					</div>
				{% endif %}
			</div><!-- /.aladin-panel -->

		</div><!-- /.image-info-grid -->

		<!-- ─────────────────────────────────────────
		     SKY COORDINATES
		──────────────────────────────────────────── -->
		{% if image.sky and image.sky.ra %}
		<div class="image-coords">
			<span>RA {{ image.sky.ra }}</span>
			<span class="sep">/</span>
			<span>Dec {{ image.sky.dec }}</span>
		</div>
		{% endif %}

		<!-- ─────────────────────────────────────────
		     DESCRIPTION
		──────────────────────────────────────────── -->
		{% if image.description %}
		<div class="image-description">
			<p>{{ image.description }}</p>
		</div>
		{% endif %}

		<!-- ─────────────────────────────────────────
		     COMMENTS (Giscus)
		──────────────────────────────────────────── -->
		<div class="comments-section">
			<h2>Comments</h2>
			{% if site.giscus.repoId and site.giscus.repoId != "PLACEHOLDER_REPO_ID" %}
				<script src="https://giscus.app/client.js"
					data-repo="{{ site.giscus.repo }}"
					data-repo-id="{{ site.giscus.repoId }}"
					data-category="{{ site.giscus.category }}"
					data-category-id="{{ site.giscus.categoryId }}"
					data-mapping="pathname"
					data-strict="0"
					data-reactions-enabled="1"
					data-emit-metadata="0"
					data-input-position="top"
					data-theme="dark"
					data-lang="en"
					crossorigin="anonymous"
					async>
				</script>
			{% else %}
				<p class="text-muted" style="font-size:0.875rem;">
					Comments will be enabled after Giscus is configured — see <code>src/_data/site.json</code>.
				</p>
			{% endif %}
		</div>

		<!-- ─────────────────────────────────────────
		     PREV / NEXT IMAGE NAVIGATION
		     pagination.href.previous / .next are 11ty's built-in
		     links for adjacent pagination pages. pagination.page.previous
		     / .next give the full data object for that page so we can
		     show the adjacent image's title.
		──────────────────────────────────────────── -->
		{% if pagination.href.previous or pagination.href.next %}
		<nav class="image-nav" aria-label="Browse other images">

			{% if pagination.href.previous %}
			<a href="{{ pagination.href.previous }}" class="image-nav-link image-nav-link--prev">
				<span class="image-nav-dir">&#x2190; Previous</span>
				{% if pagination.page.previous %}
				<span class="image-nav-title">{{ pagination.page.previous.title }}</span>
				{% endif %}
			</a>
			{% else %}
			<span class="image-nav-spacer"></span>
			{% endif %}

			{% if pagination.href.next %}
			<a href="{{ pagination.href.next }}" class="image-nav-link image-nav-link--next">
				<span class="image-nav-dir">Next &#x2192;</span>
				{% if pagination.page.next %}
				<span class="image-nav-title">{{ pagination.page.next.title }}</span>
				{% endif %}
			</a>
			{% else %}
			<span class="image-nav-spacer"></span>
			{% endif %}

		</nav>
		{% endif %}

	</div><!-- /.image-detail-body -->
</article>


<!-- ═══════════════════════════════════════════════════════════
     ZOOM LIGHTBOX (dzi_url images only)
     Full-viewport overlay containing the OSD deep zoom viewer.
     Sits outside <article> so it covers the entire screen —
     nav bar, footer, everything — without z-index conflicts.
═══════════════════════════════════════════════════════════════ -->

{% if image.dzi_url %}
<div
	id="zoom-lightbox"
	class="zoom-lightbox"
	hidden
	role="dialog"
	aria-modal="true"
	aria-label="{{ image.title }} — full resolution viewer"
>
	<!--
		Controls bar — top-right corner.
		Annotate button (if applicable) and Close button sit here as peers
		so neither is absolutely positioned inside the viewer canvas area.
	-->
	<div class="lightbox-controls">
		{% if image.annotated_dzi_url %}
		<button id="annotate-toggle" class="annotate-btn lightbox-annotate" aria-pressed="false">
			Show Annotations
		</button>
		{% endif %}
		{#
			Objects button — only rendered when annotations are present in images.json.
			Toggles the OSD overlay labels that mark catalog objects in the image.
		#}
		{% if image.annotations and image.annotations | length > 0 %}
		<button id="objects-toggle" class="annotate-btn lightbox-annotate" aria-pressed="false">
			Show Objects
		</button>
		{% endif %}
		<button id="lightbox-close" class="lightbox-close">✕ Close</button>
	</div>

	<!--
		OSD renders into this div. Inside the lightbox it gets width:100% height:100%
		via CSS so it fills the entire viewport with no cropping.
	-->
	<div
		id="osd-viewer"
		class="image-viewer"
		role="img"
		aria-label="{{ image.title }}"
	></div>
</div>


<!-- ═══════════════════════════════════════════════════════════
     VIEWER SCRIPTS
     OSD is loaded but not initialized until the lightbox opens.
═══════════════════════════════════════════════════════════════ -->

<!--
	OpenSeadragon v6 — deep zoom tile viewer.
	Pinned version, loaded from jsDelivr CDN.
-->
<script src="https://cdn.jsdelivr.net/npm/openseadragon@6.0.2/build/openseadragon/openseadragon.min.js"></script>
<script>
(function () {
	var dziUrl       = {{ image.dzi_url | dump | safe }};
	var annotatedUrl = {{ image.annotated_dzi_url | dump | safe }};

	var lightbox    = document.getElementById('zoom-lightbox');
	var trigger     = document.getElementById('zoom-trigger');
	var closeBtn    = document.getElementById('lightbox-close');
	var annotBtn    = document.getElementById('annotate-toggle');
	var objectsBtn  = document.getElementById('objects-toggle');

	// OSD instance — created once, reused on subsequent opens
	var viewer = null;

	// Annotation overlay elements — populated after OSD loads the first tile set.
	// Each element is a div positioned by OSD at the annotation's image coordinates.
	var annotationEls     = [];
	var showingObjects    = false;

	// Annotation data from images.json — serialised to JS via | dump.
	// Each entry: { name: string, x: number (0-1), y: number (0-1) }
	var annotations = {{ (image.annotations or []) | dump | safe }};

	// ── Open lightbox ────────────────────────────────────────────────────
	function openLightbox() {
		lightbox.hidden = false;
		// Lock page scroll so the user can't accidentally scroll
		// the page while panning inside the lightbox
		document.body.style.overflow = 'hidden';

		// Initialize OSD on first open only — lazy so tiles don't
		// start downloading until the user actually wants to zoom
		if (!viewer) {
			viewer = OpenSeadragon({
				id: 'osd-viewer',
				prefixUrl: 'https://cdn.jsdelivr.net/npm/openseadragon@6.0.2/build/openseadragon/images/',
				tileSources: dziUrl,

				// Minimap
				showNavigator:       true,
				navigatorPosition:   'BOTTOM_RIGHT',
				navigatorSizeRatio:  0.12,
				navigatorAutoResize: false,

				// CORS required for R2-hosted tiles (different origin from the page)
				crossOriginPolicy: 'Anonymous',

				showZoomControl:     true,
				showHomeControl:     true,
				showFullPageControl: false,  // we ARE the fullscreen; redundant here
				showRotationControl: false,

				animationTime: 0.4,
				blendTime:     0.1,

				// Default zoomPerClick is 2.0 (doubles/halves each press — too jumpy).
				// 1.4 zooms by 40% per button click, which feels gradual and controlled.
				// zoomPerScroll controls the mouse wheel step; 1.15 is slightly finer
				// than the default 1.2 to match the more precise button feel.
				zoomPerClick:  1.4,
				zoomPerScroll: 1.15,

				// Fit the whole image on first load
				defaultZoomLevel: 0,

				gestureSettingsMouse: {
					scrollToZoom:   true,
					clickToZoom:    false,
					dblClickToZoom: true,
					dragToPan:      true,
				},
				gestureSettingsTouch: {
					pinchToZoom:  true,
					dragToPan:    true,
					flickEnabled: true,
				},

				maxImageCacheCount: 300,
			});

			// Block right-click save on the canvas
			document.getElementById('osd-viewer').addEventListener('contextmenu', function (e) {
				e.preventDefault();
			});

			// Tile load error
			viewer.addHandler('open-failed', function () {
				var el = document.getElementById('osd-viewer');
				viewer.destroy();
				viewer = null;
				el.innerHTML = '<div class="osd-error">Could not load image tiles. Check that the DZI file and tile folder are uploaded to R2.</div>';
			});

			// ── Tile-source annotation toggle (annotated_dzi_url) ────────────
			if (annotBtn && annotatedUrl) {
				var showingAnnotated = false;

				annotBtn.addEventListener('click', function () {
					showingAnnotated = !showingAnnotated;
					viewer.open(showingAnnotated ? annotatedUrl : dziUrl);
					annotBtn.textContent = showingAnnotated ? 'Hide Annotations' : 'Show Annotations';
					annotBtn.setAttribute('aria-pressed', showingAnnotated ? 'true' : 'false');
				});
			}

			// ── Catalog object overlay (platesolve-style labels) ────────────
			// After the first tile set is loaded, create a DOM overlay element
			// for each annotation and register it with OSD at the correct
			// viewport position. OSD keeps the element locked to that position
			// as the user pans and zooms.
			if (annotations && annotations.length) {
				viewer.addHandler('open', function () {
					// Only add overlays once (guard against the open event firing
					// again when annotated tile source is swapped in)
					if (annotationEls.length) return;

					// getContentSize() returns the pixel dimensions of the loaded image
					var imgSize = viewer.world.getItemAt(0).getContentSize();

					annotations.forEach(function (ann) {
						// Build the label element.
						// The outer div is the OSD overlay anchor (0×0, overflow visible).
						// The dot appears at the anchor point; the label extends to its right.
						var el = document.createElement('div');
						el.className  = 'osd-annotation';
						el.style.display = 'none'; // hidden until the toggle fires
						el.innerHTML =
							'<span class="osd-annotation-dot"></span>' +
							'<span class="osd-annotation-label">' + ann.name + '</span>';

						// Convert 0-1 fraction → image pixels → OSD viewport coordinates.
						// imageToViewportCoordinates handles the aspect-ratio normalisation.
						var vpPt = viewer.viewport.imageToViewportCoordinates(
							ann.x * imgSize.x,
							ann.y * imgSize.y
						);

						viewer.addOverlay({
							element:  el,
							location: vpPt,
						});

						annotationEls.push(el);
					});
				});

				// Toggle all annotation labels on/off
				if (objectsBtn) {
					objectsBtn.addEventListener('click', function () {
						showingObjects = !showingObjects;
						annotationEls.forEach(function (el) {
							el.style.display = showingObjects ? 'block' : 'none';
						});
						objectsBtn.textContent = showingObjects ? 'Hide Objects' : 'Show Objects';
						objectsBtn.setAttribute('aria-pressed', showingObjects ? 'true' : 'false');
					});
				}
			}
		}

		// Return focus to close button for keyboard accessibility
		if (closeBtn) closeBtn.focus();
	}

	// ── Close lightbox ───────────────────────────────────────────────────
	function closeLightbox() {
		lightbox.hidden = true;
		document.body.style.overflow = '';
		// Return focus to the trigger so keyboard users aren't stranded
		if (trigger) trigger.focus();
	}

	// ── Event wiring ─────────────────────────────────────────────────────
	if (trigger)  trigger.addEventListener('click',  openLightbox);
	if (closeBtn) closeBtn.addEventListener('click',  closeLightbox);

	// ── Keyboard navigation ──────────────────────────────────────────────
	// Handled at the document level so the user doesn't need to click into
	// the viewer first — any key press while the lightbox is open works.
	//
	// Arrow keys: pan the viewport by 10% per press.
	//   OpenSeadragon.Point(x, y) is in viewport coordinates where 1.0 = full
	//   viewport width. 0.1 gives a noticeable but not jarring step.
	//
	// + / = : zoom in  (same factor as the on-screen buttons: 1.4)
	// - / _ : zoom out
	//
	// Escape: close lightbox (already handled below, merged here for clarity)
	//
	// e.preventDefault() on arrow keys stops the page from scrolling behind
	// the lightbox while it's open.
	document.addEventListener('keydown', function (e) {
		if (lightbox.hidden) return;

		if (e.key === 'Escape') {
			closeLightbox();
			return;
		}

		// Remaining shortcuts require the viewer to be initialised
		if (!viewer) return;

		var vp      = viewer.viewport;
		var panStep = 0.1; // fraction of viewport per keypress

		switch (e.key) {
			case 'ArrowLeft':
				e.preventDefault();
				vp.panBy(new OpenSeadragon.Point(-panStep, 0));
				break;
			case 'ArrowRight':
				e.preventDefault();
				vp.panBy(new OpenSeadragon.Point(panStep, 0));
				break;
			case 'ArrowUp':
				e.preventDefault();
				vp.panBy(new OpenSeadragon.Point(0, -panStep));
				break;
			case 'ArrowDown':
				e.preventDefault();
				vp.panBy(new OpenSeadragon.Point(0, panStep));
				break;
			case '+':
			case '=':
				// zoomBy() multiplies the current zoom by the given factor.
				// applyConstraints() snaps back if the new level exceeds min/max.
				vp.zoomBy(1.4);
				vp.applyConstraints();
				break;
			case '-':
			case '_':
				vp.zoomBy(1 / 1.4);
				vp.applyConstraints();
				break;
		}
	});
}());
</script>

{% elif image.full_url and image.annotated_url %}
<!--
	Fallback annotation toggle for images without a tile pyramid.
	Swaps the <img> src between the clean and annotated JPEG.
-->
<script>
(function () {
	var img = document.getElementById('hero-img');
	var btn = document.getElementById('annotate-toggle');
	if (!img || !btn) return;

	var cleanSrc     = img.dataset.clean;
	var annotatedSrc = img.dataset.annotated;
	if (!annotatedSrc) return;

	var showingAnnotated = false;

	btn.addEventListener('click', function () {
		showingAnnotated = !showingAnnotated;
		img.src = showingAnnotated ? annotatedSrc : cleanSrc;
		btn.textContent = showingAnnotated ? 'Hide Annotations' : 'Show Annotations';
		btn.setAttribute('aria-pressed', showingAnnotated ? 'true' : 'false');
	});
}());
</script>
{% endif %}
