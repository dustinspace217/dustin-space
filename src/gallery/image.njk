---
pagination:
  data: images
  size: 1
  alias: image
permalink: "gallery/{{ image.slug }}/"
layout: "layouts/base.njk"
---

{#
	Phase 3 — Variant loop.

	Each target has one or more variants (different equipment/sessions).
	Single-variant targets render identically to the pre-variant layout.
	Multi-variant targets stack variant sections vertically, each with its
	own hero image, equipment, acquisition, and sky atlas.

	pv      = primary variant (gallery tile, JSON-LD, page hero)
	isMulti = true when the target has more than one variant
#}
{% set pv = image.variants | selectattr("primary") | first %}
{% set pv = pv or image.variants[0] %}
{% set isMulti = image.variants | length > 1 %}

{#
	JSON-LD structured data — injected into <head> via the layout's {% block head %}.
	schema.org/ImageObject tells Google the image's title, description, creator, date,
	and canonical URL. Uses the primary variant for image URLs.

	| dump serialises Nunjucks values to JSON-safe strings — handles quotes,
	newlines, and special characters so the inline JSON stays valid.
#}
{% set heroSrcForLD = pv.preview_url or pv.full_url or pv.thumbnail %}
{% block head %}
{#
	Preload the hero image — it's the LCP (Largest Contentful Paint) element on
	detail pages. Without this, the browser doesn't start fetching until it parses
	the <img> tag mid-page. The preload hint moves the fetch to the earliest moment.
	`as="image"` assigns high fetch priority; `fetchpriority="high"` doubles down.
#}
{% if heroSrcForLD %}
<link rel="preload" as="image" href="{{ heroSrcForLD }}" fetchpriority="high" />
{% endif %}
{# Preconnect to external origins used on this page (CDN scripts, tile server) #}
<link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
{#
	selectattr("dzi_url") filters to variants where dzi_url is truthy (non-null).
	If any variant has DZI tiles, preconnect to the tile server.
#}
{% if image.variants | selectattr("dzi_url") | list | length > 0 %}
<link rel="preconnect" href="https://tiles.dustin.space" crossorigin />
{% endif %}
<script type="application/ld+json">
{
	"@context": "https://schema.org",
	"@type": "ImageObject",
	"name": {{ image.title | dump | safe }},
	"description": {{ (image.description or "") | dump | safe }},
	"contentUrl": {{ (heroSrcForLD or "") | dump | safe }},
	"thumbnailUrl": {{ (pv.thumbnail or "") | dump | safe }},
	"datePublished": {{ pv.date | dump | safe }},
	"url": "{{ site.url }}/gallery/{{ image.slug }}/",
	"author": {
		"@type": "Person",
		"name": {{ site.author | dump | safe }}
	},
	"creator": {
		"@type": "Person",
		"name": {{ site.author | dump | safe }}
	},
	"keywords": {{ (image.tags | join(", ")) | dump | safe }}
}
</script>
{% endblock %}

<!--
	IMAGE DETAIL PAGE
	`image` is the aliased pagination item — the single target object from images.json.

	PAGE HERO — the primary variant's image. For single-variant targets the hero
	doubles as the zoom trigger (current behaviour). For multi-variant targets it's
	a static context image; each variant section below has its own zoom trigger.

	LIGHTBOX (dzi_url path only):
	  Clicking a zoom trigger opens a full-viewport lightbox. OSD is initialised
	  lazily — it doesn't load until the first click. The lightbox covers 100vw×100vh
	  so OSD has no height constraint and the entire image is visible. Body scroll
	  is locked while the lightbox is open. Escape key or the Close button dismisses it.

	ANNOTATION TOGGLE:
	  Deep zoom mode:  swaps tile source via viewer.open(annotated_dzi_url)
	  Fallback mode:   swaps <img> src between full_url and annotated_url
-->

{# Aladin Lite v3 injects its CSS dynamically — no separate link tag needed. #}

<article class="image-detail">

	<!-- ─────────────────────────────────────────────────────
	     PAGE HERO — Primary variant's image (LCP element)
	──────────────────────────────────────────────────────── -->
	<div class="image-hero-wrap">

		<!--
			Back link — frosted chip in the top-left corner of the hero,
			always visible over the image. Uses history.back() when the visitor
			came from the gallery so any active filter (?filter=messier) is
			preserved in the URL.
		-->
		<a href="/gallery/" class="hero-back-link" id="back-link">← Gallery</a>
		<script>
			(function () {
				var ref = document.referrer;
				if (ref && ref.includes(location.host) && ref.includes('/gallery/')) {
					document.getElementById('back-link').addEventListener('click', function (e) {
						e.preventDefault();
						history.back();
					});
				}
			}());
		</script>

		{% if not isMulti and pv.dzi_url %}
			<!--
				Single-variant with DZI: page hero IS the zoom trigger.
				Clicking opens the full-viewport lightbox with the OSD deep zoom viewer.
				The button element makes it keyboard-accessible without extra ARIA work.
				data-variant tells detail.js which variant's DZI to load.
			-->
			<button
				class="zoom-trigger"
				data-variant="{{ pv.id }}"
				aria-label="Open {{ image.title }} in full-resolution viewer"
				aria-haspopup="dialog"
			>
				{#
					Preview priority:
					  1. preview_url  — medium-res (~2400px) hosted on R2, best quality
					  2. full_url     — local full-resolution image
					  3. thumbnail    — AstroBin 620px fallback; add preview_url to fix pixelation
				#}
				{% if heroSrcForLD %}
					<img
						src="{{ heroSrcForLD }}"
						alt="{{ image.title }}"
						class="zoom-trigger-img"
						width="2400"
						height="1600"
						fetchpriority="high"
					/>
				{% else %}
					<div class="image-hero image-hero--placeholder" aria-hidden="true">✦</div>
				{% endif %}

				<!-- Floating hint at the bottom of the preview -->
				<span class="zoom-trigger-hint" aria-hidden="true">&#x2315; Explore full resolution</span>
			</button>

		{% elif not isMulti and pv.full_url %}
			<!--
				Single-variant without DZI: plain image while tile pyramid is being prepared.
				Supports the annotated_url swap if present.
			-->
			<img
				id="hero-img"
				class="image-hero"
				src="{{ pv.full_url }}"
				alt="{{ image.title }}"
				data-clean="{{ pv.full_url }}"
				data-annotated="{{ pv.annotated_url or '' }}"
			/>

			{% if pv.annotated_url %}
				<button id="annotate-toggle-hero" class="annotate-btn" aria-pressed="false">
					Show Annotations
				</button>
			{% endif %}

		{% elif isMulti and heroSrcForLD %}
			<!--
				Multi-variant: static hero image for LCP and visual context.
				Each variant section below has its own zoom trigger.
			-->
			<img
				src="{{ heroSrcForLD }}"
				alt="{{ image.title }}"
				class="image-hero"
				width="2400"
				height="1600"
				fetchpriority="high"
			/>

		{% else %}
			<div class="image-hero image-hero--placeholder" aria-hidden="true">✦</div>
		{% endif %}

	</div><!-- /.image-hero-wrap -->

	<!-- ─────────────────────────────────────────────────────
	     STATS STRIP — key acquisition metrics at a glance.
	     Computed from existing variant data — no extra schema fields needed.
	     For single-variant targets: shows primary variant stats.
	     For multi-variant: each variant section gets its own strip.
	──────────────────────────────────────────────────────── -->
	{% if not isMulti and pv.acquisition and pv.acquisition.filters | length %}
	{% set statIntMin = pv.acquisition.filters | formatExposure %}
	{% set statFrames = pv.acquisition.filters | totalFrames %}
	{% set statFov = pv.sky.fov_w | fovArcmin(pv.sky.fov_h) if pv.sky else null %}
	{% if statIntMin != "—" or statFrames > 0 or statFov %}
	<div class="stats-strip" aria-label="Image statistics">
		{% if statIntMin and statIntMin != "—" %}
		<span class="stat-item">
			<span class="stat-value">{{ statIntMin }}</span>
			<span class="stat-label">Integration</span>
		</span>
		{% endif %}
		{% if statFrames > 0 %}
		<span class="stat-item">
			<span class="stat-value">{{ statFrames }}</span>
			<span class="stat-label">Frames</span>
		</span>
		{% endif %}
		{% if pv.acquisition.filters | length > 1 %}
		<span class="stat-item">
			<span class="stat-value">{{ pv.acquisition.filters | length }}</span>
			<span class="stat-label">Filters</span>
		</span>
		{% endif %}
		{% if statFov %}
		<span class="stat-item">
			<span class="stat-value">{{ statFov }}</span>
			<span class="stat-label">Field of View</span>
		</span>
		{% endif %}
	</div>
	{% endif %}
	{% endif %}

	<div class="image-detail-body">

		<!-- ─────────────────────────────────────────
		     TITLE + CATALOG + DATE
		──────────────────────────────────────────── -->
		<div class="image-detail-header">
			<h1>{{ image.title }}</h1>
			<div class="image-catalog">{{ image.catalog }}</div>
			{#
				Date and location appear in the header for single-variant targets only.
				Multi-variant targets show date/location inside each variant section.
			#}
			{% if not isMulti %}
			<div class="image-date">
				{{ pv.date | readableDate }}
				{% if pv.equipment %} &mdash; {{ pv.equipment.location }}{% endif %}
			</div>
			{% endif %}
			<!--
				AstroBin deep link — only rendered when astrobin_id is set in images.json.
				Opens in a new tab so the visitor stays on the detail page.
				rel="noopener noreferrer" prevents the opened tab from accessing
				window.opener and avoids leaking the referrer URL.
			-->
			{% if image.astrobin_id %}
			<a
				href="https://www.astrobin.com/{{ image.astrobin_id }}/"
				class="astrobin-link"
				target="_blank"
				rel="noopener noreferrer"
			>View on AstroBin ↗</a>
			{% endif %}
			<!--
				Share button — uses the native Web Share API when available
				(mobile browsers, Edge, Chrome). Falls back to copying the
				URL to the clipboard on desktop where the API isn't supported.
				The button text updates briefly to confirm the action.
			-->
			<button class="share-btn" id="share-btn"
				data-title="{{ image.title }}"
				data-url="{{ site.url }}/gallery/{{ image.slug }}/"
			>
				<svg class="share-icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
					<circle cx="15" cy="4"  r="2"/>
					<circle cx="15" cy="16" r="2"/>
					<circle cx="4"  cy="10" r="2"/>
					<line x1="6" y1="11" x2="13" y2="15"/>
					<line x1="6" y1="9"  x2="13" y2="5"/>
				</svg>
				<span class="share-btn-label">Share</span>
			</button>
			<script>
			(function () {
				var btn   = document.getElementById('share-btn');
				var label = btn ? btn.querySelector('.share-btn-label') : null;
				if (!btn) return;

				btn.addEventListener('click', function () {
					var title = btn.dataset.title;
					var url   = btn.dataset.url;

					// navigator.share() is the native share sheet (iOS Safari, Android Chrome,
					// Edge). It opens the OS-level share dialog with the title and URL.
					if (navigator.share) {
						navigator.share({ title: title, url: url }).catch(function () {});
						return;
					}

					// Clipboard fallback for desktop browsers that don't support Web Share.
					navigator.clipboard.writeText(url).then(function () {
						if (label) {
							label.textContent = 'Copied!';
							setTimeout(function () { label.textContent = 'Share'; }, 2000);
						}
					}).catch(function () {
						// Last resort: select the URL in a prompt so the user can copy manually
						window.prompt('Copy link:', url);
					});
				});
			}());
			</script>
		</div>

		<!-- ─────────────────────────────────────────
		     DESCRIPTION — placed before the technical metadata
		     so the general audience gets context first, and the
		     astrophotography community can scroll to the specs.
		──────────────────────────────────────────── -->
		{% if image.description %}
		<div class="image-description">
			<p>{{ image.description }}</p>
		</div>
		{% endif %}

		<!-- ─────────────────────────────────────────
		     OBJECT INFO PANEL — astronomical properties of the target
		     from Simbad data and manual entries. Placed after the
		     description so it reads as "about this object" context
		     before the technical per-variant metadata below.
		──────────────────────────────────────────── -->
		{% if image.object_info %}
		<div class="object-info-panel">
			<h2 class="object-info-title">About {{ image.target or image.title }}</h2>
			<div class="object-info-grid">
				{% if image.object_info.object_type %}
				<div class="oi-item">
					<span class="oi-label">Type</span>
					<span class="oi-value">{{ image.object_info.object_type }}</span>
				</div>
				{% endif %}
				{% if image.object_info.constellation %}
				<div class="oi-item">
					<span class="oi-label">Constellation</span>
					<span class="oi-value">{{ image.object_info.constellation }}</span>
				</div>
				{% endif %}
				{% if image.object_info.distance %}
				<div class="oi-item">
					<span class="oi-label">Distance</span>
					<span class="oi-value">{{ image.object_info.distance }}</span>
				</div>
				{% endif %}
				{% if image.object_info.apparent_size %}
				<div class="oi-item">
					<span class="oi-label">Apparent Size</span>
					<span class="oi-value">{{ image.object_info.apparent_size }}</span>
				</div>
				{% endif %}
				{% if image.object_info.visual_magnitude %}
				<div class="oi-item">
					<span class="oi-label">Magnitude</span>
					<span class="oi-value">{{ image.object_info.visual_magnitude }}</span>
				</div>
				{% endif %}
			</div>
			{# Other designations: alternate catalog names for the same target.
			   Shows as a comma-separated list below the grid. #}
			{% if image.object_info.other_designations and image.object_info.other_designations | length %}
			<p class="oi-designations">Also known as: {{ image.object_info.other_designations | join(', ') }}</p>
			{% endif %}
		</div>
		{% endif %}


		<!-- ═════════════════════════════════════════════════════════════
		     VARIANT LOOP
		     Each variant is a self-contained section with its own hero,
		     metadata tables, and sky atlas. Single-variant targets run
		     the loop once with no variant header — layout is identical
		     to the previous single-image design.
		═════════════════════════════════════════════════════════════ -->
		{% for variant in image.variants %}
		<section class="variant-section" id="{{ variant.id }}">

			{% if isMulti %}
			<!--
				Variant header — only shown when the target has multiple variants.
				Labels describe the equipment/FOV/filter palette so the visitor
				can tell variants apart at a glance.
			-->
			<h2 class="variant-header">{{ variant.label }}</h2>

			<!-- Per-variant hero image with zoom trigger -->
			<div class="image-hero-wrap variant-hero-wrap">
				{% set vHero = variant.preview_url or variant.full_url or variant.thumbnail %}
				{% if variant.dzi_url %}
					<button
						class="zoom-trigger"
						data-variant="{{ variant.id }}"
						aria-label="Open {{ image.title }} — {{ variant.label }} in full-resolution viewer"
						aria-haspopup="dialog"
					>
						{% if vHero %}
							<img
								src="{{ vHero }}"
								alt="{{ image.title }} — {{ variant.label }}"
								class="zoom-trigger-img"
								width="2400"
								height="1600"
								loading="lazy"
							/>
						{% else %}
							<div class="image-hero image-hero--placeholder" aria-hidden="true">✦</div>
						{% endif %}
						<span class="zoom-trigger-hint" aria-hidden="true">&#x2315; Explore full resolution</span>
					</button>
				{% elif vHero %}
					<img
						src="{{ vHero }}"
						alt="{{ image.title }} — {{ variant.label }}"
						class="image-hero"
						width="2400"
						height="1600"
						loading="lazy"
					/>
				{% else %}
					<div class="image-hero image-hero--placeholder" aria-hidden="true">✦</div>
				{% endif %}
			</div>

			<!-- Date and location — per-variant for multi-variant targets -->
			<div class="image-date variant-date">
				{{ variant.date | readableDate }}
				{% if variant.equipment %} &mdash; {{ variant.equipment.location }}{% endif %}
			</div>
			{% endif %}

			<!-- ─────────────────────────────────────────
			     COMPARISON SLIDER — before/after revision comparison.
			     Only rendered when a variant has 2+ revisions with preview_url set.
			     Compares the oldest revision (before) with the newest (after).
			     Revisions-only: same raw data, different processing. Variants are
			     different imaging sessions and would not align pixel-for-pixel.
			──────────────────────────────────────────── -->
			{% set revWithPreview = variant.revisions | withPreview %}
			{% if revWithPreview | length >= 2 %}
			{# Revision order: first in array = newest (after), last = oldest (before).
			   The slider shows before on the left, after on the right. #}
			{% set beforeRev = revWithPreview[revWithPreview | length - 1] %}
			{% set afterRev = revWithPreview[0] %}
			<div class="comparison-slider"
				data-before="{{ beforeRev.preview_url }}"
				data-after="{{ afterRev.preview_url }}"
				data-before-label="{{ beforeRev.label or 'Before' }}"
				data-after-label="{{ afterRev.label or 'After' }}"
				role="img"
				aria-label="Before and after comparison: {{ beforeRev.label or 'Before' }} vs {{ afterRev.label or 'After' }}">
				<noscript>
					<p>Enable JavaScript to use the comparison slider.</p>
				</noscript>
			</div>
			{% endif %}

			<!-- ─────────────────────────────────────────
			     TWO-COLUMN INFO GRID
			     Left: acquisition + equipment tables
			     Right: sky atlas widget
			──────────────────────────────────────────── -->
			<div class="image-info-grid">

				<!-- LEFT: metadata -->
				<div class="image-meta-column">

					<!-- Per-filter exposure breakdown -->
					{% if variant.acquisition and variant.acquisition.filters %}
					<h3>Acquisition</h3>

					{% if variant.acquisition.mode == "lucky" %}
						<p class="acq-note">{{ variant.acquisition.note }}</p>
					{% endif %}

					<table class="metadata-table" aria-label="Per-filter exposure breakdown">
						<thead>
							<tr>
								<th scope="col">Filter</th>
								<th scope="col">Frames</th>
								<th scope="col">Time</th>
							</tr>
						</thead>
						<tbody>
							{% for f in variant.acquisition.filters %}
							<tr>
								<td>{{ f.name }}</td>
								<td>{{ f.frames }}</td>
								<td>{% if f.minutes %}{{ f.minutes | formatExposure }}{% else %}—{% endif %}</td>
							</tr>
							{% endfor %}
						</tbody>
						{% if variant.acquisition.filters | length > 1 %}
						<tfoot>
							<tr class="acq-total">
								<th scope="row" colspan="2">Total</th>
								<td>{{ variant.acquisition.filters | formatExposure }}</td>
							</tr>
						</tfoot>
						{% endif %}
					</table>
					{% endif %}

					<!-- Per-variant equipment -->
					{% if variant.equipment %}
					<h3>Equipment</h3>
					<table class="metadata-table" aria-label="Image acquisition equipment">
						<tbody>
							<tr><th scope="row">Telescope</th><td>{{ variant.equipment.telescope }}</td></tr>
							<tr><th scope="row">Camera</th>   <td>{{ variant.equipment.camera }}</td></tr>
							<tr><th scope="row">Mount</th>    <td>{{ variant.equipment.mount }}</td></tr>
							<tr><th scope="row">Guiding</th>  <td>{{ variant.equipment.guider }}</td></tr>
							<tr><th scope="row">Filters</th>  <td>{{ variant.equipment.filters }}</td></tr>
							<tr><th scope="row">Software</th> <td>{{ variant.equipment.software }}</td></tr>
						</tbody>
					</table>
					{% endif %}

					<!-- ─────────────────────────────────────────
					     FILE METADATA — collapsible section showing
					     source file format, dimensions, bit depth, and
					     FITS headers extracted at ingest time.
					──────────��───────────────────────────────── -->
					{% if variant.file_metadata %}
					<details class="file-metadata-panel">
						<summary>
							<h3>File Metadata</h3>
						</summary>
						<table class="metadata-table" aria-label="Source file metadata">
							<tbody>
								{% if variant.file_metadata.source_format %}
								<tr><th scope="row">Format</th><td>{{ variant.file_metadata.source_format }}</td></tr>
								{% endif %}
								{% if variant.file_metadata.dimensions %}
								<tr><th scope="row">Dimensions</th><td>{{ variant.file_metadata.dimensions }}</td></tr>
								{% endif %}
								{% if variant.file_metadata.bit_depth %}
								<tr><th scope="row">Bit Depth</th><td>{{ variant.file_metadata.bit_depth }}-bit</td></tr>
								{% endif %}
								{% if variant.file_metadata.color_space %}
								<tr><th scope="row">Color Space</th><td>{{ variant.file_metadata.color_space }}</td></tr>
								{% endif %}
								{% if variant.file_metadata.file_size_mb %}
								<tr><th scope="row">File Size</th><td>{{ variant.file_metadata.file_size_mb }} MB</td></tr>
								{% endif %}
							</tbody>
						</table>
						{# FITS headers — technical key-value pairs from the source file.
						   Iterates over the object's keys using Nunjucks's {% for k, v in obj %} syntax.
						   Only interesting headers are stored — SITELAT/SITELONG are excluded for privacy. #}
						{% if variant.file_metadata.fits_headers %}
						<h4 class="fits-heading">FITS Headers</h4>
						<table class="metadata-table metadata-table--mono" aria-label="FITS header data">
							<tbody>
								{% for key, value in variant.file_metadata.fits_headers %}
								<tr><th scope="row">{{ key }}</th><td>{{ value }}</td></tr>
								{% endfor %}
							</tbody>
						</table>
						{% endif %}
					</details>
					{% endif %}

				</div><!-- /.image-meta-column -->

				<!-- RIGHT: Aladin Lite sky atlas -->
				<div class="aladin-panel">
					<h3>Sky Position</h3>

					{% if variant.sky and variant.sky.aladin_target %}
						<!--
							Aladin Lite container — detail.js initialises this via IntersectionObserver.
							Each variant gets its own container with a unique ID so multi-variant
							pages can show sky atlases at different coordinates.
							The sky data is passed through the JSON bridge (#image-data).
						-->
						<div id="aladin-{{ variant.id }}" class="aladin-lite-container"></div>
					{% else %}
						<div class="aladin-na">
							Sky atlas not available for solar images.
						</div>
					{% endif %}
				</div><!-- /.aladin-panel -->

			</div><!-- /.image-info-grid -->

			<!-- ─────────────────────────────────────────
			     SKY COORDINATES
			──────────────────────────────────────────── -->
			{% if variant.sky and variant.sky.ra %}
			<div class="image-coords">
				<span>RA {{ variant.sky.ra }}</span>
				<span class="sep">/</span>
				<span>Dec {{ variant.sky.dec }}</span>
				{#
					Bortle class indicator — small colored badge showing the
					Bortle Dark-Sky Scale class (1-9) for the imaging location.
					Color ranges from dark green (class 1, excellent) through
					amber/red (class 9, inner-city). Only renders when bortle is set.
				#}
				{% if variant.sky.bortle %}
				<span class="sep">/</span>
				<span class="bortle-badge" data-bortle="{{ variant.sky.bortle }}" aria-label="Bortle class {{ variant.sky.bortle }}">
					Bortle {{ variant.sky.bortle }}
				</span>
				{% endif %}
			</div>

			{#
				Bortle scale gauge — 9 segments from dark (1) to bright (9).
				The active segment (matching this image's bortle class) is
				highlighted and scaled up. Each segment is colored to match
				the Bortle scale: dark green → amber → red.
				Descriptive label appears below the gauge.

				Privacy: no coordinates appear here. The bortle value was derived
				from lat/lon at ingest time — only the integer class is stored.
			#}
			{% if variant.sky.bortle %}
			<div class="bortle-gauge-wrap">
				<span class="bortle-gauge-title">Sky Quality</span>
				<div class="bortle-gauge" role="img" aria-label="Bortle scale class {{ variant.sky.bortle }} — {{ variant.sky.bortle | bortleLabel }}">
					{% for b in range(1, 10) %}
					<span class="bortle-seg{% if b == variant.sky.bortle %} bortle-seg--active{% endif %}" data-bortle="{{ b }}" title="Bortle {{ b }}">{{ b }}</span>
					{% endfor %}
				</div>
				<span class="bortle-gauge-label">{{ variant.sky.bortle | bortleLabel }}</span>
			</div>
			{% endif %}
			{% endif %}

			<!-- ─────────────────────────────────────────
			     PROCESSING NOTES — collapsible section showing
			     the photographer's processing workflow, software used,
			     and session details. Plain text with double-newline
			     paragraph breaks. Only rendered when data is present.
			──────────────────────────────────────────── -->
			{% if variant.processing_notes %}
			<details class="processing-notes">
				<summary>
					<h3>Processing</h3>
				</summary>
				<div class="processing-notes-body">
					{# Split on double-newline to create paragraphs. Safe because
					   processing_notes is plain text, and autoescape is enabled
					   (HTML entities are escaped automatically by Nunjucks). #}
					{% for para in variant.processing_notes | split('\n\n') %}
					<p>{{ para }}</p>
					{% endfor %}
				</div>
			</details>
			{% endif %}

		</section>
		{% endfor %}

		<!-- ─────────────────────────────────────────
		     COMMENTS (Giscus)
		──────────────────────────────────────────── -->
		<div class="comments-section">
			<h2>Comments</h2>
			{% if site.giscus.repoId and site.giscus.repoId != "PLACEHOLDER_REPO_ID" %}
				<!--
					Giscus is loaded lazily via IntersectionObserver.
					The ~40KB client script is only fetched when the comments
					section scrolls into view (300px margin to preload slightly early).
					This avoids downloading it for visitors who never reach the bottom.
				-->
				<div id="giscus-container"></div>
				<script>
				(function () {
					var container = document.getElementById('giscus-container');
					if (!container || !('IntersectionObserver' in window)) {
						// Fallback: inject immediately if IntersectionObserver unavailable.
						loadGiscus();
						return;
					}
					var loaded = false;
					var observer = new IntersectionObserver(function (entries) {
						if (!entries[0].isIntersecting || loaded) return;
						loaded = true;
						observer.disconnect();
						loadGiscus();
					}, { rootMargin: '300px' });
					observer.observe(container);

					function loadGiscus() {
						var s = document.createElement('script');
						s.src = 'https://giscus.app/client.js';
						s.setAttribute('data-repo',             '{{ site.giscus.repo }}');
						s.setAttribute('data-repo-id',          '{{ site.giscus.repoId }}');
						s.setAttribute('data-category',         '{{ site.giscus.category }}');
						s.setAttribute('data-category-id',      '{{ site.giscus.categoryId }}');
						s.setAttribute('data-mapping',          'pathname');
						s.setAttribute('data-strict',           '0');
						s.setAttribute('data-reactions-enabled','1');
						s.setAttribute('data-emit-metadata',    '0');
						s.setAttribute('data-input-position',   'top');
						s.setAttribute('data-theme',            'dark');
						s.setAttribute('data-lang',             'en');
						s.setAttribute('crossorigin',           'anonymous');
						s.async = true;
						container.appendChild(s);
					}
				}());
				</script>
			{% else %}
				<p class="text-muted" style="font-size:0.875rem;">
					Comments will be enabled after Giscus is configured — see <code>src/_data/site.json</code>.
				</p>
			{% endif %}
		</div>

		<!-- ─────────────────────────────────────────
		     PREV / NEXT IMAGE NAVIGATION
		     pagination.href.previous / .next are 11ty's built-in
		     links for adjacent pagination pages. pagination.page.previous
		     / .next give the full data object for that page so we can
		     show the adjacent image's title.
		──────────────────────────────────────────── -->
		{% if pagination.href.previous or pagination.href.next %}
		<nav class="image-nav" aria-label="Browse other images">

			{% if pagination.href.previous %}
			<a href="{{ pagination.href.previous }}" class="image-nav-link image-nav-link--prev">
				<span class="image-nav-dir">&#x2190; Previous</span>
				{% if pagination.page.previous %}
				<span class="image-nav-title">{{ pagination.page.previous.title }}</span>
				{% endif %}
			</a>
			{% else %}
			<span class="image-nav-spacer"></span>
			{% endif %}

			{% if pagination.href.next %}
			<a href="{{ pagination.href.next }}" class="image-nav-link image-nav-link--next">
				<span class="image-nav-dir">Next &#x2192;</span>
				{% if pagination.page.next %}
				<span class="image-nav-title">{{ pagination.page.next.title }}</span>
				{% endif %}
			</a>
			{% else %}
			<span class="image-nav-spacer"></span>
			{% endif %}

		</nav>
		{% endif %}

	</div><!-- /.image-detail-body -->
</article>


<!-- ═══════════════════════════════════════════════════════════
     ZOOM LIGHTBOX (shown if any variant has dzi_url)
     Full-viewport overlay containing the OSD deep zoom viewer.
     Sits outside <article> so it covers the entire screen —
     nav bar, footer, everything — without z-index conflicts.

     Shared across all variants — detail.js switches the tile
     source based on which zoom trigger was clicked. Annotation
     buttons are hidden/shown per-variant by JS.
═══════════════════════════════════════════════════════════════ -->

{% set variantsWithDzi = image.variants | selectattr("dzi_url") | list %}
{% if variantsWithDzi | length > 0 %}
<div
	id="zoom-lightbox"
	class="zoom-lightbox"
	hidden
	role="dialog"
	aria-modal="true"
	aria-label="{{ image.title }} — full resolution viewer"
>
	<!--
		Controls bar — top-right corner.
		Annotate and Objects buttons start hidden; detail.js shows/hides them
		based on which variant is active in the lightbox. This allows different
		variants to have different annotation sets.
	-->
	<div class="lightbox-controls">
		<button id="annotate-toggle" class="annotate-btn lightbox-annotate" aria-pressed="false" hidden>
			Show Annotations
		</button>
		<button id="objects-toggle" class="annotate-btn lightbox-annotate" aria-pressed="false" hidden>
			Show Objects
		</button>
		<button id="lightbox-close" class="lightbox-close">✕ Close</button>
	</div>

	<!--
		OSD renders into this div. Inside the lightbox it gets width:100% height:100%
		via CSS so it fills the entire viewport with no cropping.
	-->
	<div
		id="osd-viewer"
		class="image-viewer"
		aria-label="{{ image.title }}"
	></div>

	<!--
		Revision filmstrip — rendered dynamically by detail.js when the active
		variant has revisions. Contains clickable revision buttons that swap
		the OSD tile source, plus a note line below showing the active revision's
		processing description.
	-->
	<div id="revision-strip" class="revision-strip" hidden></div>
	<div id="revision-note" class="revision-note" hidden></div>

	<!-- Keyboard shortcut hint — shown at the bottom of the lightbox -->
	<p class="osd-keyboard-hint" aria-hidden="true">
		Arrow keys: pan &nbsp;·&nbsp; +/−: zoom &nbsp;·&nbsp; H: home &nbsp;·&nbsp; F: full screen &nbsp;·&nbsp; Esc: close
	</p>
</div>


<!-- ═══════════════════════════════════════════════════════════
     VIEWER SCRIPTS
     OSD CDN loaded with defer; detail.js reads #image-data and
     initialises the lightbox + Aladin on DOMContentLoaded.
═══════════════════════════════════════════════════════════════ -->

<!--
	OpenSeadragon v6 — deep zoom tile viewer.
	Pinned version, loaded from jsDelivr CDN.
	`defer` prevents this body script from blocking HTML parsing.
	`integrity` pins the exact file hash so a CDN compromise can't inject code.
	`crossorigin="anonymous"` is required for the browser to check the SRI hash.
-->
<script
	defer
	src="https://cdn.jsdelivr.net/npm/openseadragon@6.0.2/build/openseadragon/openseadragon.min.js"
	integrity="sha384-7CySh3EMRRN5r2E82ru4URZMpjhLMwArPSxxAwdtldDSsY3XQJIWwlMFR7L7ZGjl"
	crossorigin="anonymous"
></script>

{% elif not isMulti and pv.full_url and pv.annotated_url %}
<!--
	Fallback annotation toggle for single-variant images without a tile pyramid.
	Kept inline — it's 15 lines with no template variables (reads from data attributes).
-->
<script>
(function () {
	var img = document.getElementById('hero-img');
	var btn = document.getElementById('annotate-toggle-hero');
	if (!img || !btn) return;

	var cleanSrc     = img.dataset.clean;
	var annotatedSrc = img.dataset.annotated;
	if (!annotatedSrc) return;

	var showingAnnotated = false;

	btn.addEventListener('click', function () {
		showingAnnotated = !showingAnnotated;
		img.src = showingAnnotated ? annotatedSrc : cleanSrc;
		btn.textContent = showingAnnotated ? 'Hide Annotations' : 'Show Annotations';
		btn.setAttribute('aria-pressed', showingAnnotated ? 'true' : 'false');
	});
}());
</script>
{% endif %}

<!--
	JSON data bridge — all Nunjucks template data needed by detail.js.
	This <script type="application/json"> block is the ONLY place Nunjucks
	touches JavaScript data. detail.js reads it via JSON.parse and passes the
	parsed object to initLightbox() and initAladin(). This keeps Nunjucks
	template syntax entirely out of the external JS file.

	Phase 3: the bridge now passes an array of variant objects, each with its
	own DZI URL, annotations, and sky coordinates. detail.js looks up the
	active variant by ID (from the zoom trigger's data-variant attribute).
-->
<script id="image-data" type="application/json">
{
	"variants": [
		{% for variant in image.variants %}
		{
			"id": {{ variant.id | dump | safe }},
			"dziUrl": {{ variant.dzi_url | dump | safe }},
			"annotatedDziUrl": {{ variant.annotated_dzi_url | dump | safe }},
			"annotations": {{ (variant.annotations or []) | dump | safe }},
			"sky": {% if variant.sky and variant.sky.aladin_target %}{
				"containerId": {{ ("aladin-" ~ variant.id) | dump | safe }},
				"aladinTarget": {{ variant.sky.aladin_target | dump | safe }},
				"fovDeg": {{ variant.sky.fov_deg | dump | safe }},
				"raDeg": {{ variant.sky.ra_deg | dump | safe }},
				"decDeg": {{ variant.sky.dec_deg | dump | safe }},
				"fovW": {{ variant.sky.fov_w | dump | safe }},
				"fovH": {{ variant.sky.fov_h | dump | safe }}
			}{% else %}null{% endif %},
			"revisions": {{ (variant.revisions or []) | dump | safe }}
		}{% if not loop.last %},{% endif %}
		{% endfor %}
	]
}
</script>
<script defer src="/assets/js/detail.js"></script>
