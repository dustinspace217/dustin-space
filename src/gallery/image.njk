---
pagination:
  data: images
  size: 1
  alias: image
permalink: "gallery/{{ image.slug }}/"
layout: "layouts/base.njk"
---

{#
	JSON-LD structured data — injected into <head> via the layout's {% block head %}.
	schema.org/ImageObject tells Google the image's title, description, creator, date,
	and canonical URL. This enables rich results in Google Images (name, date, author
	shown beneath the thumbnail) without any visible change to the page.

	| dump serialises Nunjucks values to JSON-safe strings — handles quotes,
	newlines, and special characters so the inline JSON stays valid.
#}
{% set heroSrcForLD = image.preview_url or image.full_url or image.thumbnail %}
{% block head %}
{#
	Preload the hero image — it's the LCP (Largest Contentful Paint) element on
	detail pages. Without this, the browser doesn't start fetching until it parses
	the <img> tag mid-page. The preload hint moves the fetch to the earliest moment.
	`as="image"` assigns high fetch priority; `fetchpriority="high"` doubles down.
#}
{% if heroSrcForLD %}
<link rel="preload" as="image" href="{{ heroSrcForLD }}" fetchpriority="high" />
{% endif %}
{# Preconnect to external origins used on this page (CDN scripts, tile server) #}
<link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
{% if image.dzi_url %}
<link rel="preconnect" href="https://tiles.dustin.space" crossorigin />
{% endif %}
<script type="application/ld+json">
{
	"@context": "https://schema.org",
	"@type": "ImageObject",
	"name": {{ image.title | dump | safe }},
	"description": {{ (image.description or "") | dump | safe }},
	"contentUrl": {{ (heroSrcForLD or "") | dump | safe }},
	"thumbnailUrl": {{ (image.thumbnail or "") | dump | safe }},
	"datePublished": {{ image.date | dump | safe }},
	"url": "{{ site.url }}/gallery/{{ image.slug }}/",
	"author": {
		"@type": "Person",
		"name": {{ site.author | dump | safe }}
	},
	"creator": {
		"@type": "Person",
		"name": {{ site.author | dump | safe }}
	},
	"keywords": {{ (image.tags | join(", ")) | dump | safe }}
}
</script>
{% endblock %}

<!--
	IMAGE DETAIL PAGE
	`image` is the aliased pagination item — the single image object from images.json.

	HERO DISPLAY — three-tier fallback:
	  1. dzi_url is set  → thumbnail preview on the page; fullscreen OSD lightbox on click
	  2. full_url is set → plain <img> tag (transitional, while tiling is in progress)
	  3. neither        → placeholder div

	LIGHTBOX (dzi_url path only):
	  Clicking the thumbnail opens a full-viewport lightbox. OSD is initialized
	  lazily — it doesn't load until the first click. The lightbox covers 100vw×100vh
	  so OSD has no height constraint and the entire image is visible. Body scroll
	  is locked while the lightbox is open. Escape key or the Close button dismisses it.

	ANNOTATION TOGGLE:
	  Deep zoom mode:  swaps tile source via viewer.open(annotated_dzi_url)
	  Fallback mode:   swaps <img> src between full_url and annotated_url
-->

{# Aladin Lite v3 injects its CSS dynamically — no separate link tag needed. #}

<article class="image-detail">

	<!-- ─────────────────────────────────────────────────────
	     HERO — Zoom trigger OR Fallback Image
	──────────────────────────────────────────────────────── -->
	<div class="image-hero-wrap">

		<!--
			Back link — frosted chip in the top-left corner of the hero,
			always visible over the image. Uses history.back() when the visitor
			came from the gallery so any active filter (?filter=messier) is
			preserved in the URL.
		-->
		<a href="/gallery/" class="hero-back-link" id="back-link">← Gallery</a>
		<script>
			(function () {
				var ref = document.referrer;
				if (ref && ref.includes(location.host) && ref.includes('/gallery/')) {
					document.getElementById('back-link').addEventListener('click', function (e) {
						e.preventDefault();
						history.back();
					});
				}
			}());
		</script>

		{% if image.dzi_url %}
			<!--
				Zoom trigger — a thumbnail preview of the image.
				Clicking opens the full-viewport lightbox with the OSD deep zoom viewer.
				The button element makes it keyboard-accessible without extra ARIA work.
			-->
			<button
				class="zoom-trigger"
				id="zoom-trigger"
				aria-label="Open {{ image.title }} in full-resolution viewer"
				aria-haspopup="dialog"
			>
				{#
					Preview priority:
					  1. preview_url  — medium-res (~2400px) hosted on R2, best quality
					  2. full_url     — local full-resolution image
					  3. thumbnail    — AstroBin 620px fallback; add preview_url to fix pixelation
				#}
				{% set heroSrc = image.preview_url or image.full_url or image.thumbnail %}
				{% if heroSrc %}
					<img
						src="{{ heroSrc }}"
						alt="{{ image.title }}"
						class="zoom-trigger-img"
						width="2400"
						height="1600"
						fetchpriority="high"
					/>
				{% else %}
					<div class="image-hero image-hero--placeholder" aria-hidden="true">✦</div>
				{% endif %}

				<!-- Floating hint at the bottom of the preview -->
				<span class="zoom-trigger-hint" aria-hidden="true">&#x2315; Explore full resolution</span>
			</button>

		{% elif image.full_url %}
			<!--
				Fallback: plain image while tile pyramid is being prepared.
				Supports the existing annotated_url swap if present.
			-->
			<img
				id="hero-img"
				class="image-hero"
				src="{{ image.full_url }}"
				alt="{{ image.title }}"
				data-clean="{{ image.full_url }}"
				data-annotated="{{ image.annotated_url or '' }}"
			/>

			{% if image.annotated_url %}
				<button id="annotate-toggle" class="annotate-btn" aria-pressed="false">
					Show Annotations
				</button>
			{% endif %}

		{% else %}
			<div class="image-hero image-hero--placeholder" aria-hidden="true">✦</div>
		{% endif %}

	</div><!-- /.image-hero-wrap -->


	<div class="image-detail-body">

		<!-- ─────────────────────────────────────────
		     TITLE + CATALOG + DATE
		──────────────────────────────────────────── -->
		<div class="image-detail-header">
			<h1>{{ image.title }}</h1>
			<div class="image-catalog">{{ image.catalog }}</div>
			<div class="image-date">
				{{ image.date | readableDate }}
				{% if image.equipment %} &mdash; {{ image.equipment.location }}{% endif %}
			</div>
			<!--
				AstroBin deep link — only rendered when astrobin_id is set in images.json.
				Opens in a new tab so the visitor stays on the detail page.
				rel="noopener noreferrer" prevents the opened tab from accessing
				window.opener and avoids leaking the referrer URL.
			-->
			{% if image.astrobin_id %}
			<a
				href="https://www.astrobin.com/{{ image.astrobin_id }}/"
				class="astrobin-link"
				target="_blank"
				rel="noopener noreferrer"
			>View on AstroBin ↗</a>
			{% endif %}
			<!--
				Share button — uses the native Web Share API when available
				(mobile browsers, Edge, Chrome). Falls back to copying the
				URL to the clipboard on desktop where the API isn't supported.
				The button text updates briefly to confirm the action.
			-->
			<button class="share-btn" id="share-btn"
				data-title="{{ image.title }}"
				data-url="{{ site.url }}/gallery/{{ image.slug }}/"
			>
				<svg class="share-icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
					<circle cx="15" cy="4"  r="2"/>
					<circle cx="15" cy="16" r="2"/>
					<circle cx="4"  cy="10" r="2"/>
					<line x1="6" y1="11" x2="13" y2="15"/>
					<line x1="6" y1="9"  x2="13" y2="5"/>
				</svg>
				<span class="share-btn-label">Share</span>
			</button>
			<script>
			(function () {
				var btn   = document.getElementById('share-btn');
				var label = btn ? btn.querySelector('.share-btn-label') : null;
				if (!btn) return;

				btn.addEventListener('click', function () {
					var title = btn.dataset.title;
					var url   = btn.dataset.url;

					// navigator.share() is the native share sheet (iOS Safari, Android Chrome,
					// Edge). It opens the OS-level share dialog with the title and URL.
					if (navigator.share) {
						navigator.share({ title: title, url: url }).catch(function () {});
						return;
					}

					// Clipboard fallback for desktop browsers that don't support Web Share.
					navigator.clipboard.writeText(url).then(function () {
						if (label) {
							label.textContent = 'Copied!';
							setTimeout(function () { label.textContent = 'Share'; }, 2000);
						}
					}).catch(function () {
						// Last resort: select the URL in a prompt so the user can copy manually
						window.prompt('Copy link:', url);
					});
				});
			}());
			</script>
		</div>

		<!-- ─────────────────────────────────────────
		     DESCRIPTION — placed before the technical metadata
		     so the general audience gets context first, and the
		     astrophotography community can scroll to the specs.
		──────────────────────────────────────────── -->
		{% if image.description %}
		<div class="image-description">
			<p>{{ image.description }}</p>
		</div>
		{% endif %}

		<!-- ─────────────────────────────────────────
		     TWO-COLUMN INFO GRID
		     Left: acquisition + equipment tables
		     Right: sky atlas widget
		──────────────────────────────────────────── -->
		<div class="image-info-grid">

			<!-- LEFT: metadata -->
			<div class="image-meta-column">

				<!-- Per-filter exposure breakdown -->
				{% if image.acquisition and image.acquisition.filters %}
				<h2>Acquisition</h2>

				{% if image.acquisition.mode == "lucky" %}
					<p class="acq-note">{{ image.acquisition.note }}</p>
				{% endif %}

				<table class="metadata-table" aria-label="Per-filter exposure breakdown">
					<thead>
						<tr>
							<th scope="col">Filter</th>
							<th scope="col">Frames</th>
							<th scope="col">Time</th>
						</tr>
					</thead>
					<tbody>
						{% for f in image.acquisition.filters %}
						<tr>
							<td>{{ f.name }}</td>
							<td>{{ f.frames }}</td>
							<td>{% if f.minutes %}{{ f.minutes | formatExposure }}{% else %}—{% endif %}</td>
						</tr>
						{% endfor %}
					</tbody>
					{% if image.acquisition.filters | length > 1 %}
					<tfoot>
						<tr class="acq-total">
							<th scope="row" colspan="2">Total</th>
							<td>{{ image.acquisition.filters | formatExposure }}</td>
						</tr>
					</tfoot>
					{% endif %}
				</table>
				{% endif %}

				<!-- Per-image equipment -->
				{% if image.equipment %}
				<h2>Equipment</h2>
				<table class="metadata-table" aria-label="Image acquisition equipment">
					<tbody>
						<tr><th scope="row">Telescope</th><td>{{ image.equipment.telescope }}</td></tr>
						<tr><th scope="row">Camera</th>   <td>{{ image.equipment.camera }}</td></tr>
						<tr><th scope="row">Mount</th>    <td>{{ image.equipment.mount }}</td></tr>
						<tr><th scope="row">Guiding</th>  <td>{{ image.equipment.guider }}</td></tr>
						<tr><th scope="row">Filters</th>  <td>{{ image.equipment.filters }}</td></tr>
						<tr><th scope="row">Software</th> <td>{{ image.equipment.software }}</td></tr>
					</tbody>
				</table>
				{% endif %}

			</div><!-- /.image-meta-column -->

			<!-- RIGHT: Aladin Lite sky atlas -->
			<div class="aladin-panel">
				<h2>Sky Position</h2>

				{% if image.sky and image.sky.aladin_target %}
					<!--
						Aladin Lite container — detail.js initializes this via IntersectionObserver.
						The sky data is passed through the JSON bridge (#image-data) below.
					-->
					<div id="aladin-lite-div"></div>
				{% else %}
					<div class="aladin-na">
						Sky atlas not available for solar images.
					</div>
				{% endif %}
			</div><!-- /.aladin-panel -->

		</div><!-- /.image-info-grid -->

		<!-- ─────────────────────────────────────────
		     SKY COORDINATES
		──────────────────────────────────────────── -->
		{% if image.sky and image.sky.ra %}
		<div class="image-coords">
			<span>RA {{ image.sky.ra }}</span>
			<span class="sep">/</span>
			<span>Dec {{ image.sky.dec }}</span>
		</div>
		{% endif %}

		<!-- ─────────────────────────────────────────
		     COMMENTS (Giscus)
		──────────────────────────────────────────── -->
		<div class="comments-section">
			<h2>Comments</h2>
			{% if site.giscus.repoId and site.giscus.repoId != "PLACEHOLDER_REPO_ID" %}
				<!--
					Giscus is loaded lazily via IntersectionObserver.
					The ~40KB client script is only fetched when the comments
					section scrolls into view (300px margin to preload slightly early).
					This avoids downloading it for visitors who never reach the bottom.
				-->
				<div id="giscus-container"></div>
				<script>
				(function () {
					var container = document.getElementById('giscus-container');
					if (!container || !('IntersectionObserver' in window)) {
						// Fallback: inject immediately if IntersectionObserver unavailable.
						loadGiscus();
						return;
					}
					var loaded = false;
					var observer = new IntersectionObserver(function (entries) {
						if (!entries[0].isIntersecting || loaded) return;
						loaded = true;
						observer.disconnect();
						loadGiscus();
					}, { rootMargin: '300px' });
					observer.observe(container);

					function loadGiscus() {
						var s = document.createElement('script');
						s.src = 'https://giscus.app/client.js';
						s.setAttribute('data-repo',             '{{ site.giscus.repo }}');
						s.setAttribute('data-repo-id',          '{{ site.giscus.repoId }}');
						s.setAttribute('data-category',         '{{ site.giscus.category }}');
						s.setAttribute('data-category-id',      '{{ site.giscus.categoryId }}');
						s.setAttribute('data-mapping',          'pathname');
						s.setAttribute('data-strict',           '0');
						s.setAttribute('data-reactions-enabled','1');
						s.setAttribute('data-emit-metadata',    '0');
						s.setAttribute('data-input-position',   'top');
						s.setAttribute('data-theme',            'dark');
						s.setAttribute('data-lang',             'en');
						s.setAttribute('crossorigin',           'anonymous');
						s.async = true;
						container.appendChild(s);
					}
				}());
				</script>
			{% else %}
				<p class="text-muted" style="font-size:0.875rem;">
					Comments will be enabled after Giscus is configured — see <code>src/_data/site.json</code>.
				</p>
			{% endif %}
		</div>

		<!-- ─────────────────────────────────────────
		     PREV / NEXT IMAGE NAVIGATION
		     pagination.href.previous / .next are 11ty's built-in
		     links for adjacent pagination pages. pagination.page.previous
		     / .next give the full data object for that page so we can
		     show the adjacent image's title.
		──────────────────────────────────────────── -->
		{% if pagination.href.previous or pagination.href.next %}
		<nav class="image-nav" aria-label="Browse other images">

			{% if pagination.href.previous %}
			<a href="{{ pagination.href.previous }}" class="image-nav-link image-nav-link--prev">
				<span class="image-nav-dir">&#x2190; Previous</span>
				{% if pagination.page.previous %}
				<span class="image-nav-title">{{ pagination.page.previous.title }}</span>
				{% endif %}
			</a>
			{% else %}
			<span class="image-nav-spacer"></span>
			{% endif %}

			{% if pagination.href.next %}
			<a href="{{ pagination.href.next }}" class="image-nav-link image-nav-link--next">
				<span class="image-nav-dir">Next &#x2192;</span>
				{% if pagination.page.next %}
				<span class="image-nav-title">{{ pagination.page.next.title }}</span>
				{% endif %}
			</a>
			{% else %}
			<span class="image-nav-spacer"></span>
			{% endif %}

		</nav>
		{% endif %}

	</div><!-- /.image-detail-body -->
</article>


<!-- ═══════════════════════════════════════════════════════════
     ZOOM LIGHTBOX (dzi_url images only)
     Full-viewport overlay containing the OSD deep zoom viewer.
     Sits outside <article> so it covers the entire screen —
     nav bar, footer, everything — without z-index conflicts.
═══════════════════════════════════════════════════════════════ -->

{% if image.dzi_url %}
<div
	id="zoom-lightbox"
	class="zoom-lightbox"
	hidden
	role="dialog"
	aria-modal="true"
	aria-label="{{ image.title }} — full resolution viewer"
>
	<!--
		Controls bar — top-right corner.
		Annotate button (if applicable) and Close button sit here as peers
		so neither is absolutely positioned inside the viewer canvas area.
	-->
	<div class="lightbox-controls">
		{% if image.annotated_dzi_url %}
		<button id="annotate-toggle" class="annotate-btn lightbox-annotate" aria-pressed="false">
			Show Annotations
		</button>
		{% endif %}
		{#
			Objects button — only rendered when annotations are present in images.json.
			Toggles the OSD overlay labels that mark catalog objects in the image.
		#}
		{% if image.annotations and image.annotations | length > 0 %}
		<button id="objects-toggle" class="annotate-btn lightbox-annotate" aria-pressed="false">
			Show Objects
		</button>
		{% endif %}
		<button id="lightbox-close" class="lightbox-close">✕ Close</button>
	</div>

	<!--
		OSD renders into this div. Inside the lightbox it gets width:100% height:100%
		via CSS so it fills the entire viewport with no cropping.
		role="img" is intentionally omitted — it would make the div opaque to
		assistive technology, hiding OSD's interactive zoom/home buttons from
		keyboard and screen reader users. OSD manages its own ARIA hierarchy.
	-->
	<div
		id="osd-viewer"
		class="image-viewer"
		aria-label="{{ image.title }}"
	></div>

	<!-- Keyboard shortcut hint — shown at the bottom of the lightbox -->
	<p class="osd-keyboard-hint" aria-hidden="true">
		Arrow keys: pan &nbsp;·&nbsp; +/−: zoom &nbsp;·&nbsp; H: home &nbsp;·&nbsp; F: full screen &nbsp;·&nbsp; Esc: close
	</p>
</div>


<!-- ═══════════════════════════════════════════════════════════
     VIEWER SCRIPTS
     OSD CDN loaded with defer; detail.js reads #image-data and
     initialises the lightbox + Aladin on DOMContentLoaded.
═══════════════════════════════════════════════════════════════ -->

<!--
	OpenSeadragon v6 — deep zoom tile viewer.
	Pinned version, loaded from jsDelivr CDN.
	`defer` prevents this body script from blocking HTML parsing.
	`integrity` pins the exact file hash so a CDN compromise can't inject code.
	`crossorigin="anonymous"` is required for the browser to check the SRI hash.
-->
<script
	defer
	src="https://cdn.jsdelivr.net/npm/openseadragon@6.0.2/build/openseadragon/openseadragon.min.js"
	integrity="sha384-7CySh3EMRRN5r2E82ru4URZMpjhLMwArPSxxAwdtldDSsY3XQJIWwlMFR7L7ZGjl"
	crossorigin="anonymous"
></script>

{% elif image.full_url and image.annotated_url %}
<!--
	Fallback annotation toggle for images without a tile pyramid.
	Kept inline — it's 15 lines with no template variables (reads from data attributes).
-->
<script>
(function () {
	var img = document.getElementById('hero-img');
	var btn = document.getElementById('annotate-toggle');
	if (!img || !btn) return;

	var cleanSrc     = img.dataset.clean;
	var annotatedSrc = img.dataset.annotated;
	if (!annotatedSrc) return;

	var showingAnnotated = false;

	btn.addEventListener('click', function () {
		showingAnnotated = !showingAnnotated;
		img.src = showingAnnotated ? annotatedSrc : cleanSrc;
		btn.textContent = showingAnnotated ? 'Hide Annotations' : 'Show Annotations';
		btn.setAttribute('aria-pressed', showingAnnotated ? 'true' : 'false');
	});
}());
</script>
{% endif %}

<!--
	JSON data bridge �� all Nunjucks template data needed by detail.js.
	This <script type="application/json"> block is the ONLY place Nunjucks
	touches JavaScript data. detail.js reads it via JSON.parse and passes the
	parsed object to initLightbox() and initAladin(). This keeps Nunjucks
	template syntax entirely out of the external JS file.
-->
<script id="image-data" type="application/json">
{
	"dziUrl": {{ image.dzi_url | dump | safe }},
	"annotatedDziUrl": {{ image.annotated_dzi_url | dump | safe }},
	"annotations": {{ (image.annotations or []) | dump | safe }},
	"sky": {% if image.sky and image.sky.aladin_target %}{
		"aladinTarget": {{ image.sky.aladin_target | dump | safe }},
		"fovDeg": {{ image.sky.fov_deg | dump | safe }},
		"raDeg": {{ image.sky.ra_deg | dump | safe }},
		"decDeg": {{ image.sky.dec_deg | dump | safe }},
		"fovW": {{ image.sky.fov_w | dump | safe }},
		"fovH": {{ image.sky.fov_h | dump | safe }}
	}{% else %}null{% endif %}
}
</script>
<script defer src="/assets/js/detail.js"></script>
