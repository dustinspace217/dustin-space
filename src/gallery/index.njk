---
layout: layouts/base.njk
title: Gallery
description: "Deep sky astrophotography — nebulae, galaxies, planetary, and solar images by Dustin K."
permalink: /gallery/
galleryPage: true
---

<!--
	GALLERY INDEX PAGE
	Displays all images with category filtering.
	`images` is the full array from src/_data/images.json.
-->

<!-- Page header -->
<div class="page-banner container">
	<h1>Gallery</h1>
	<p class="page-subtitle">{{ images | length }} images — Nebulae · Galaxies · Clusters · Solar</p>
</div>

<div class="container" style="padding-bottom: 80px;">

	<!--
		Filter pills — each data-filter value matches a slug from the image's
		data-tags attribute (a space-separated list of subject tags + catalog slugs).
		A card is shown if its data-tags list includes the selected filter.
		"all" always shows everything.

		Two visual groups:
		  1. Subject type (galaxy, emission-nebula, etc.)
		  2. Catalog collections (messier, caldwell) — gold accent, visually distinct
	-->
	<div class="gallery-filters" role="group" aria-label="Filter images">

		<div class="filter-group" role="group" aria-label="Filter by subject type">
			<button class="filter-btn active" data-filter="all"              aria-pressed="true">All</button>
			<button class="filter-btn" data-filter="galaxy"                  aria-pressed="false">Galaxy</button>
			<button class="filter-btn" data-filter="emission-nebula"         aria-pressed="false">Emission Nebula</button>
			<button class="filter-btn" data-filter="supernova-remnant"       aria-pressed="false">Supernova</button>
			<button class="filter-btn" data-filter="dark-nebula"             aria-pressed="false">Dark Nebula</button>
			<button class="filter-btn" data-filter="reflection-nebula"       aria-pressed="false">Reflection Nebula</button>
			<button class="filter-btn" data-filter="open-cluster"            aria-pressed="false">Open Cluster</button>
			<button class="filter-btn" data-filter="solar"                   aria-pressed="false">Solar</button>
		</div>

		<div class="filter-group filter-group--catalogs" role="group" aria-label="Filter by catalog collection">
			<span class="filter-group-label">Collections</span>
			<button class="filter-btn filter-btn--catalog" data-filter="messier"  aria-pressed="false">Messier</button>
			<button class="filter-btn filter-btn--catalog" data-filter="caldwell" aria-pressed="false">Caldwell</button>
		</div>

	</div>

	<!--
		Filter result count — updated by gallery.js whenever the active filter changes.
		aria-live="polite" means screen readers will announce the updated count
		without interrupting the user. The initial text is set server-side so it
		renders correctly even before JS runs.
	-->
	<p class="filter-count" aria-live="polite">Showing all {{ images | length }} images</p>

	<!-- Gallery grid — all images -->
	<div class="gallery-grid">

		<!--
			Static empty-state paragraph. Must be in the HTML at page load so
			screen readers register the aria-live region before any content
			changes — dynamically injected aria-live elements are ignored by
			NVDA and JAWS. gallery.js queries this element by class and
			shows/hides it rather than creating it.
		-->
		<p class="gallery-empty hidden" aria-live="polite" role="status">No images in this category yet.</p>

		<!--
			`images` is the full array from src/_data/images.json, accessed directly.
			Sorting is applied here in the template with Nunjucks' sort filter:
			sort(true, false, "date") = descending, case-sensitive, sorted by the "date" field.
			Newest images appear first.
		-->
		<!--
			data-tags: space-separated list combining subject tags (e.g. "emission-nebula") and catalog
			slugs (e.g. "messier"). gallery.js checks .includes() against this list for filtering.
			The first subject tag (image.tags[0]) drives the badge color via CSS [data-tag="..."].
		-->
		{% for image in images | sort(true, false, "date") %}
		<a href="/gallery/{{ image.slug }}/" class="gallery-card" data-tags="{{ image.tags | join(' ') }}{% if image.catalogs %} {{ image.catalogs | join(' ') }}{% endif %}">

			<div class="card-thumb">
				{% if image.thumbnail %}
					<img
						src="{{ image.thumbnail }}"
						alt="{{ image.title }}"
						width="600"
						height="400"
						loading="{{ 'eager' if loop.index <= 3 else 'lazy' }}"
					/>
				{% else %}
					<div class="card-thumb-placeholder" aria-hidden="true">✦</div>
				{% endif %}
			</div>

			<!--
				data-tag (singular): the primary/first tag, used by CSS to pick the badge accent color.
				replace('-', ' ') + capitalize turns "emission-nebula" into "Emission nebula".
			-->
			<span class="card-category" data-tag="{{ image.tags[0] }}">
				{{ image.tags[0] | replace('-', ' ') | capitalize }}
			</span>

			<div class="card-body">
				<div class="card-title">{{ image.title }}</div>
				<div class="card-catalog">{{ image.catalog }}</div>
				<div class="card-meta">
					<!--
						formatExposure accepts the acquisition.filters array and sums the minutes.
						Guard against acquisition: null (6 of 11 images have no acquisition data).
					-->
					<span>{{ image.acquisition.filters | formatExposure if image.acquisition else "—" }}</span>
					<span>{{ image.date | readableDate }}</span>
				</div>
			</div>

		</a>
		{% endfor %}

	</div>
</div>
