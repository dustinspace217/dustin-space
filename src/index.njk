---
layout: layouts/base.njk
title: ""
bodyClass: home
description: "Astrophotography by Dustin K. — nebulae, galaxies, and the Sun captured through a telescope."
ogImage: /assets/img/og-home.jpg
---

<!--
	HOME PAGE
	`images` comes from src/_data/images.json — 11ty loads all _data files
	automatically and makes them available as template variables by filename.
	`site` comes from src/_data/site.json.
-->

<!-- ===== HERO ===== -->
<section class="hero">

	<!--
		Background image — replace the gradient with your best astrophoto.
		The image is set as a CSS background-image. You can swap it to any
		of your gallery images. The gradient fallback ensures the page looks
		reasonable even before images load.
	-->
	<div class="hero-bg" style="background-image: url('/assets/img/hero-bg.jpg'); background-color: #09090f;"></div>

	<!-- Dark gradient overlay for text legibility -->
	<div class="hero-overlay"></div>

	<div class="hero-content">

		<!-- Large logo — split into styled spans so each part gets its own color -->
		<div class="hero-logo" aria-label="Dust In Space">
			<span class="logo-dust">DUST</span><span class="logo-dot">·</span><span class="logo-in">IN</span><span class="logo-dot">·</span><span class="logo-space">SPACE</span>
		</div>

		<p class="hero-tagline">{{ site.tagline }}</p>

		<a href="/gallery/" class="hero-cta">Explore the Gallery</a>
	</div>

	<!-- Animated scroll indicator -->
	<div class="hero-scroll" aria-hidden="true">Scroll</div>

</section>

<!-- ===== RECENT WORK ===== -->
<section class="recent-work">
	<div class="container">

		<div class="section-header">
			<h2>Recent Work</h2>
			<a href="/gallery/" class="view-all-link">View All</a>
		</div>

		<!--
			Show only featured images on the home page.
			`images` is the full array from images.json.
			`selectattr` is a Nunjucks filter that selects items where a
			given attribute equals a given value — like Array.filter() in JS.
		-->
		<div class="gallery-grid">
			{% for image in images | selectattr("featured", "equalto", true) %}
			<a href="/gallery/{{ image.slug }}/" class="gallery-card" data-category="{{ image.category }}">

				<div class="card-thumb">
					{% if image.thumbnail %}
						<img
							src="{{ image.thumbnail }}"
							alt="{{ image.title }}"
							loading="lazy"
						/>
					{% else %}
						<!-- Placeholder shown until a real thumbnail is provided -->
						<div class="card-thumb-placeholder" aria-hidden="true">✦</div>
					{% endif %}
				</div>

				<!-- Category tag positioned over the thumbnail via absolute CSS -->
				<span class="card-category" data-category="{{ image.category }}">
					{{ image.category | capitalize }}
				</span>

				<div class="card-body">
					<div class="card-title">{{ image.title }}</div>
					<div class="card-catalog">{{ image.catalog }}</div>
					<div class="card-meta">
						<span>{{ image.acquisition.filters | formatExposure }}</span>
						<span>{{ image.date | readableDate }}</span>
					</div>
				</div>

			</a>
			{% endfor %}
		</div>

	</div>
</section>

<!-- ===== INTRO BLURB ===== -->
<section class="home-intro">
	<div class="container">
		<div class="home-intro-inner">
			<h2>Light From Across the Universe</h2>
			<p>
				Every image here represents hours — sometimes dozens of hours — of photons
				collected from nebulae, galaxies, and our own Sun. From my backyard in the
				Pacific Northwest to remote observatories in New Mexico and Australia,
				I chase the deep sky with a camera, a telescope, and a lot of patience.
			</p>
			<p style="margin-top: 1rem;">
				Welcome to <strong>DUST·IN·SPACE</strong>.
			</p>
		</div>
	</div>
</section>

<!--
	SCROLL-DRIVEN TITLE ANIMATION
	Only active on the home page (bodyClass: home).

	Two-phase animation:

	  PHASE 1 — Logo stays in normal document flow (scrolls with the page,
	  stays above the tagline). As the user scrolls, a CSS scale() transform
	  shrinks the logo visually without affecting its layout size, so the
	  tagline position never shifts. transform-origin is "top center" so
	  the logo shrinks downward from its top edge.

	  PHASE 2 — When the logo has naturally scrolled to the height of the
	  nav bar (meaning phase1End pixels have been scrolled), the logo switches
	  to position:fixed at the nav bar. Because the logo was already at that
	  viewport Y when the switch happens, there is no jump.

	  A spacer div is inserted at the Phase 1→2 transition so the content
	  below (tagline, CTA) doesn't jump when the logo leaves normal flow.

	  On mobile (≤768px) the animation is skipped — the nav logo is always
	  visible, controlled by a CSS media-query override.
-->
<script>
(function () {
	var heroLogo   = document.querySelector('.hero-logo');
	var navLogo    = document.querySelector('.site-logo');
	var scrollHint = document.querySelector('.hero-scroll');
	if (!heroLogo) return;

	// Skip on mobile — nav logo always visible there
	if (window.innerWidth <= 768) return;

	// ── Measure the logo's natural position before touching anything ──────────
	var rect          = heroLogo.getBoundingClientRect();
	var heroFontPx    = parseFloat(getComputedStyle(heroLogo).fontSize);
	// startTop: viewport Y of the logo's top edge when scrollY === 0
	// (equals document Y because the page starts at the top)
	var startTop      = rect.top;
	var logoHeight    = rect.height;
	var logoMarginBot = parseFloat(getComputedStyle(heroLogo).marginBottom);

	// ── Constants ─────────────────────────────────────────────────────────────
	var NAV_H      = 64;    // px — must match .header-inner height in CSS
	var ROOT_FS    = parseFloat(getComputedStyle(document.documentElement).fontSize);
	var navFontPx  = 1.1 * ROOT_FS;  // matches .site-logo font-size: 1.1rem
	// Where the fixed logo should sit so its top is centered in the nav bar
	var navLogoTop = (NAV_H - navFontPx) / 2;
	// The scale at which the logo visually matches nav-logo size
	var navScale   = navFontPx / heroFontPx;
	// Phase 1 ends when scrollY has brought the logo's top to navLogoTop.
	// At that scroll amount, startTop - scrollY = navLogoTop → scrollY = startTop - navLogoTop
	var phase1End  = startTop - navLogoTop;

	// Set shrink anchor to the top-center of the logo so it collapses
	// toward its top edge rather than toward its center
	heroLogo.style.transformOrigin = 'top center';

	// Pre-build the spacer (not yet inserted — added at Phase 1→2 transition)
	// Its height matches the logo's full layout height so the tagline doesn't jump
	var spacer = document.createElement('div');
	spacer.setAttribute('aria-hidden', 'true');
	spacer.style.height       = logoHeight       + 'px';
	spacer.style.marginBottom = logoMarginBot    + 'px';
	spacer.style.flexShrink   = '0';

	// Hide nav logo on desktop; JS shows it once the hero logo is in the nav bar
	if (navLogo) {
		navLogo.style.opacity    = '0';
		navLogo.style.transition = 'opacity 0.2s';
		navLogo.style.pointerEvents = 'none';
	}

	function lerp(a, b, t)  { return a + (b - a) * t; }
	function ease(t)        { return t * t * (3 - 2 * t); }  // smoothstep

	var inNav   = false;
	var ticking = false;

	// Called once when scrollY crosses phase1End heading downward.
	// Switches the logo from in-flow (scaled) to fixed in the nav bar.
	function enterNav() {
		inNav = true;
		// Insert spacer to hold the layout gap the logo is vacating
		if (!spacer.parentNode) heroLogo.parentNode.insertBefore(spacer, heroLogo);
		// Pin logo to nav bar
		heroLogo.style.position      = 'fixed';
		heroLogo.style.top           = navLogoTop    + 'px';
		heroLogo.style.left          = '50%';
		heroLogo.style.transform     = 'translateX(-50%)';
		heroLogo.style.transformOrigin = 'center center';
		heroLogo.style.fontSize      = navFontPx     + 'px';
		heroLogo.style.letterSpacing = '0.12em';
		heroLogo.style.margin        = '0';
		heroLogo.style.zIndex        = '200';
		heroLogo.style.opacity       = '1';
		heroLogo.style.pointerEvents = 'auto';
		// Hand off brand to the real nav logo, which is at the same position
		if (navLogo) { navLogo.style.opacity = '1'; navLogo.style.pointerEvents = 'auto'; }
	}

	// Called when the user scrolls back up above phase1End.
	// Returns logo to normal flow so it scrolls with the hero again.
	function exitNav() {
		inNav = false;
		if (spacer.parentNode) spacer.parentNode.removeChild(spacer);
		// Remove all overrides — CSS takes back control
		heroLogo.style.position      = '';
		heroLogo.style.top           = '';
		heroLogo.style.left          = '';
		heroLogo.style.fontSize      = '';
		heroLogo.style.letterSpacing = '';
		heroLogo.style.margin        = '';
		heroLogo.style.zIndex        = '';
		heroLogo.style.transformOrigin = 'top center';
		// transform and opacity will be set below in the Phase 1 block
		if (navLogo) { navLogo.style.opacity = '0'; navLogo.style.pointerEvents = 'none'; }
	}

	function update() {
		var scrollY = window.scrollY;

		if (scrollY >= phase1End) {
			if (!inNav) enterNav();
		} else {
			if (inNav) exitNav();
		}

		if (!inNav) {
			// Phase 1: logo is in normal flow and scales in place
			// p goes 0→1 as the user scrolls from 0 to phase1End
			var p  = Math.min(1, Math.max(0, scrollY / phase1End));
			var ep = ease(p);
			// Scale the logo visually without shifting its layout footprint.
			// Letter-spacing scales toward the nav logo value in em units.
			heroLogo.style.transform     = 'scale(' + lerp(1, navScale, ep) + ')';
			heroLogo.style.letterSpacing = lerp(0.15, 0.12, ep) + 'em';
			// Fade out the "Scroll" hint immediately on first scroll movement
			if (scrollHint) {
				scrollHint.style.opacity = String(Math.max(0, 1 - p * 6));
			}
		}

		ticking = false;
	}

	window.addEventListener('scroll', function () {
		if (!ticking) { requestAnimationFrame(update); ticking = true; }
	}, { passive: true });

	window.addEventListener('resize', function () {
		if (window.innerWidth <= 768) {
			// Resize to mobile: undo everything and restore natural state
			if (inNav) exitNav();
			heroLogo.style.transform     = '';
			heroLogo.style.transformOrigin = '';
			heroLogo.style.letterSpacing = '';
			if (navLogo) {
				navLogo.style.opacity    = '';
				navLogo.style.transition = '';
				navLogo.style.pointerEvents = '';
			}
			return;
		}
		// Desktop resize: re-measure from the spacer (or logo, if not in nav)
		if (!inNav) {
			var r    = heroLogo.getBoundingClientRect();
			startTop = r.top + window.scrollY;
			// Temporarily clear the scale so we get the base font size
			heroLogo.style.transform = '';
			heroFontPx = parseFloat(getComputedStyle(heroLogo).fontSize);
			navScale   = navFontPx / heroFontPx;
			phase1End  = startTop - navLogoTop;
		}
		if (!ticking) { requestAnimationFrame(update); ticking = true; }
	}, { passive: true });

	// Run once on load to handle pages that load already scrolled
	update();
}());
</script>
