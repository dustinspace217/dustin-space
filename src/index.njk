---
layout: layouts/base.njk
title: ""
bodyClass: home
description: "Astrophotography by Dustin K. — nebulae, galaxies, and the Sun captured through a telescope."
ogImage: /assets/img/og-home.jpg
---

{#
	Preload the hero background image — it's the LCP (Largest Contentful Paint)
	element, so getting it fetching early reduces perceived load time.
	`as="image"` tells the browser to assign image fetch priority instead of
	the default "low" priority a background-image would otherwise receive.
#}
{% block head %}
<link rel="preload" as="image" href="/assets/img/hero-bg-veil-srgb.webp" type="image/webp" />
{% endblock %}

<!--
	HOME PAGE
	`publishedImages` comes from src/_data/publishedImages.js — a derived
	data file that filters out any entry in images.json marked
	`"published": false`. We use the filtered list (not the raw `images`
	global) so unpublished placeholders never appear in the Recent Work grid.
	`site` comes from src/_data/site.json.
-->

<!-- ===== HERO ===== -->
<section class="hero">

	<!--
		Background image — replace the gradient with your best astrophoto.
		The image is set as a CSS background-image. You can swap it to any
		of your gallery images. The gradient fallback ensures the page looks
		reasonable even before images load.
	-->
	<div class="hero-bg" style="background-image: url('/assets/img/hero-bg-veil-srgb.webp'); background-color: #09090f;"></div>

	<!-- Dark gradient overlay for text legibility -->
	<div class="hero-overlay"></div>

	<div class="hero-content">

		<!-- Large logo — split into styled spans so each part gets its own color -->
		<div class="hero-logo" aria-label="Dust In Space">
			<span class="logo-dust">DUST</span><span class="logo-dot">·</span><span class="logo-in">IN</span><span class="logo-dot">·</span><span class="logo-space">SPACE</span>
		</div>

		<p class="hero-tagline">{{ site.tagline }}</p>

		<a href="/gallery/" class="hero-cta">Explore the Gallery</a>
	</div>

	<!-- Animated scroll indicator -->
	<div class="hero-scroll" aria-hidden="true">Scroll</div>

</section>

<!--
	NAV SLOT BORDER — desktop only, home page only.
	Positioned at exactly the nav bar's bottom edge. z-index: 201 puts it
	above the sliding hero title (z-index: 200) so it remains visible as
	the title slides through it — the "card through slot" visual.
	JS fades this out after the title settles in the nav bar.
-->
<div class="nav-slot-border" aria-hidden="true"></div>

<!-- ===== RECENT WORK ===== -->
<section class="recent-work">
	<div class="container">

		<div class="section-header">
			<h2>Latest Captures</h2>
		</div>

		<!--
			Homepage preview grid — sorted newest-first.

			STRUCTURE: Each image is wrapped in .gallery-card-wrap rather than
			being a plain <a>. This wrapper lets us add a <button> as a sibling
			to the <a> link — nesting <button> inside <a> is invalid HTML, but
			siblings inside a shared <div> wrapper is perfectly fine.

			ROWS: 3-column grid. Items 1–6 (rows 1–2) are always visible.
			Items 7–15 (rows 3–5) carry .gallery-card-wrap--extra and are
			hidden by CSS until the "View more" button is clicked.

			FADE: .gallery-fade-overlay is a gradient over the grid that visually
			"cuts off" row 2, inviting the user to click "View more". JS removes
			it when the grid is expanded.
		-->
		<div class="gallery-preview-wrap">
			<div class="gallery-grid gallery-grid--home" id="home-gallery-grid">

				{% for image in publishedImages | sortByDate %}
				{% if loop.index <= 15 %}
				{# Resolve primary variant for thumbnail and metadata #}
				{% set pv = image.variants | primaryVariant %}

				<div class="gallery-card-wrap{% if loop.index > 6 %} gallery-card-wrap--extra{% endif %}">

					<a href="/gallery/{{ image.slug }}/" class="gallery-card" data-tags="{{ image.tags | join(' ') }}">

						<div class="card-thumb">
							{% if pv.thumbnail %}
								<img
									src="{{ pv.thumbnail }}"
									alt="{{ image.title }}"
									loading="{{ 'eager' if loop.index <= 3 else 'lazy' }}"
								/>
							{% else %}
								<div class="card-thumb-placeholder" aria-hidden="true">✦</div>
							{% endif %}

							{% if image.variants | length > 1 %}
							<span class="variant-count" aria-label="{{ image.variants | length }} variants">
								⊞ {{ image.variants | length }}
							</span>
							{% endif %}

							{# Distance badge — bottom-right of thumbnail #}
							{% if image.distance_display %}
							<span class="distance-badge" aria-label="{{ image.distance_display }} distance">{{ image.distance_display }}</span>
							{% endif %}

							{# Hover description — one-line teaser on hover #}
							{% if image.short_description %}
							<span class="card-hover-desc">{{ image.short_description }}</span>
							{% endif %}
						</div>

						<span class="card-category" data-tag="{{ image.tags[0] }}">
							{{ image.tags[0] | replace('-', ' ') | capitalize }}
						</span>

						<div class="card-body">
							<div class="card-title">{{ image.title }}</div>
							<div class="card-catalog">{{ image.catalog }}</div>
							<div class="card-meta">
								<span>{{ pv.acquisition.filters | formatExposure if pv.acquisition else "—" }}</span>
								<span>{{ pv.date | readableDate }}</span>
							</div>
						</div>

					</a>

				</div><!-- /.gallery-card-wrap -->
				{% endif %}
				{% endfor %}

			</div><!-- /#home-gallery-grid -->

			<!--
				Gradient overlay that fades out the second row of cards.
				Always rendered — the fade frames the grid as a preview regardless
				of total image count. JS adds .hidden to dissolve it on expand.
			-->
			<div class="gallery-fade-overlay" id="gallery-fade-overlay" aria-hidden="true"></div>

		</div><!-- /.gallery-preview-wrap -->

		<!--
			"View more" button — always shown.
			Clicking it dissolves the fade, reveals extra cards (if any), and
			surfaces the "View All" link. JS adds .hidden after expansion.
		-->
		<div class="gallery-view-more-row" id="gallery-view-more-row">
			<button class="gallery-view-more-btn" id="gallery-view-more-btn">View More</button>
		</div>

		<!--
			"View All" link — hidden until View More is clicked.
		-->
		<div class="gallery-view-all-row" id="gallery-view-all-row">
			<a href="/gallery/" class="hero-cta">View All Images</a>
		</div>

	</div>
</section>

<!-- ===== INTRO BLURB ===== -->
<section class="home-intro">
	<div class="container">
		<div class="home-intro-inner">
			<h2>Light From Across the Universe</h2>
			<p>
				Every image here represents hours — sometimes dozens of hours — of photons
				collected from nebulae, galaxies, and our own Sun. From my backyard in the
				Pacific Northwest to remote observatories in New Mexico and Australia,
				I chase the deep sky with a camera, a telescope, and a lot of patience.
			</p>
			<p style="margin-top: 1rem;">
				Welcome to <strong>DUST·IN·SPACE</strong>.
			</p>
		</div>
	</div>
</section>

<!--
	HOMEPAGE GALLERY — View More

	Clicking #gallery-view-more-btn adds .expanded to the grid container,
	which reveals .gallery-card-wrap--extra rows (3–5) via CSS specificity,
	dissolves the fade overlay, and shows the "View All" row.
-->
<script>
(function () {
	// ── View More ──────────────────────────────────────────────────────────────
	var viewMoreBtn = document.getElementById('gallery-view-more-btn');
	var viewMoreRow = document.getElementById('gallery-view-more-row');
	var viewAllRow  = document.getElementById('gallery-view-all-row');
	var fadeOverlay = document.getElementById('gallery-fade-overlay');

	if (viewMoreBtn) {
		viewMoreBtn.addEventListener('click', function () {
			// Add .expanded to the grid container — CSS rule
			// .gallery-grid--home.expanded .gallery-card-wrap--extra { display: block }
			// overrides the default display:none. Using classList + CSS specificity
			// instead of inline style.display because the class-level rule wins over
			// clearing an inline style (which was the previous broken approach).
			var grid = document.getElementById('home-gallery-grid');
			if (grid) grid.classList.add('expanded');
			// Dissolve the gradient fade overlay
			if (fadeOverlay) fadeOverlay.classList.add('hidden');
			// Hide the "View more" button
			if (viewMoreRow) viewMoreRow.classList.add('hidden');
			// Show the "View All" button at the bottom
			if (viewAllRow) viewAllRow.classList.add('visible');
		});
	}

}());
</script>

<!--
	SCROLL-DRIVEN TITLE ANIMATION
	Only active on the home page (bodyClass: home).

	Two-phase animation:

	  PHASE 1 — Logo stays in normal document flow (scrolls with the page,
	  stays above the tagline). As the user scrolls, a CSS scale() transform
	  shrinks the logo visually without affecting its layout size, so the
	  tagline position never shifts. transform-origin is "top center" so
	  the logo shrinks downward from its top edge.

	  PHASE 2 — When the logo has naturally scrolled to the height of the
	  nav bar (meaning phase1End pixels have been scrolled), the logo switches
	  to position:fixed at the nav bar. Because the logo was already at that
	  viewport Y when the switch happens, there is no jump.

	  A spacer div is inserted at the Phase 1→2 transition so the content
	  below (tagline, CTA) doesn't jump when the logo leaves normal flow.

	  On mobile (≤768px) the animation is skipped — the nav logo is always
	  visible, controlled by a CSS media-query override.
-->
<script>
(function () {
	var heroLogo   = document.querySelector('.hero-logo');
	var navLogo    = document.querySelector('.site-logo');
	var scrollHint = document.querySelector('.hero-scroll');
	var slotBorder = document.querySelector('.nav-slot-border');
	if (!heroLogo) return;

	// Respect the user's OS-level motion preference (Settings → Accessibility
	// → Reduce Motion on macOS, or equivalent on other platforms).
	// CSS already handles prefers-reduced-motion for its own transitions;
	// this check covers the JS-driven scroll animation that CSS can't reach.
	// When reduced motion is preferred, skip the animation entirely and
	// let the static nav logo show via its default CSS rules.
	if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

	// ── Per-device animation tuning ───────────────────────────────────────────
	// The animation runs on both desktop AND mobile (mobile re-enabled 2026-04-22).
	// These knobs shape how the scroll animation FEELS on each form factor
	// independently. Edit the values inside either branch below to tune.
	//
	//   easeFn            — curve mapping linear scroll progress (0–1) to
	//                        rendered progress. Cubic (t*t*t) stays near 0 for
	//                        most of the scroll and snaps sharply to 1 at the
	//                        end — "hold then slot" feel. Quadratic (t*t) is
	//                        gentler; linear (t) is fully proportional.
	//   phase1Multiplier  — scales the scroll threshold where the animation
	//                        completes. 1.0 = finishes exactly when the logo
	//                        would naturally reach the nav position. <1.0 =
	//                        finishes sooner (faster response); >1.0 = later
	//                        (longer runway — useful if mobile's shorter hero
	//                        makes the natural distance feel rushed).
	function pickConfig() {
		if (window.innerWidth <= 768) {
			return {
				// Mobile — starting values; iterate from real-device feel
				easeFn:           function (t) { return t * t; },   // quadratic — gentler than cubic
				phase1Multiplier: 1.0,                              // natural scroll runway
			};
		}
		return {
			// Desktop — preserves pre-mobile-enable behavior exactly
			easeFn:           function (t) { return t * t * t; },   // cubic ease-in
			phase1Multiplier: 1.0,
		};
	}
	var cfg = pickConfig();

	// ── Measure the logo's natural position before touching anything ──────────
	var rect          = heroLogo.getBoundingClientRect();
	var heroFontPx    = parseFloat(getComputedStyle(heroLogo).fontSize);
	// startTop: viewport Y of the logo's top edge at page load (scrollY === 0)
	var startTop      = rect.top;
	var logoHeight    = rect.height;
	var logoMarginBot = parseFloat(getComputedStyle(heroLogo).marginBottom);

	// ── Constants ─────────────────────────────────────────────────────────────
	var NAV_H      = 64;    // px — must match .header-inner height in CSS
	var ROOT_FS    = parseFloat(getComputedStyle(document.documentElement).fontSize);
	var navFontPx  = 1.1 * ROOT_FS;  // matches .site-logo font-size: 1.1rem
	// Where the fixed logo sits so it's vertically centered in the nav bar
	var navLogoTop = (NAV_H - navFontPx) / 2;
	// The scale at which the hero logo visually matches nav-logo size
	var navScale   = navFontPx / heroFontPx;
	// Phase 1 ends when the logo's top edge has reached navLogoTop,
	// scaled by the per-device multiplier (1.0 = natural).
	var phase1End  = (startTop - navLogoTop) * cfg.phase1Multiplier;

	// (Previously defined lsStartPx / lsEndPx here for per-frame
	//  letter-spacing animation from 0.15em → 0.12em — removed
	//  2026-04-22 to eliminate text re-flow cost on mobile.
	//  See update() for the trade-off note.)


	// (Crossfade removed 2026-04-22: the hero title is now the single element
	//  that animates all the way into the nav slot, rather than two elements
	//  fading between each other at the end. See enterNav()/exitNav() and the
	//  absence of a fade-range block in update() below for the new contract.)

	// ── Insert spacer to hold the layout gap ──────────────────────────────────
	// Once heroLogo is position:fixed it leaves normal flow. Without a spacer,
	// the tagline and CTA would jump upward to fill the gap.
	var spacer = document.createElement('div');
	spacer.setAttribute('aria-hidden', 'true');
	spacer.style.height       = logoHeight    + 'px';
	spacer.style.marginBottom = logoMarginBot + 'px';
	spacer.style.flexShrink   = '0';
	heroLogo.parentNode.insertBefore(spacer, heroLogo);

	// ── Switch logo to position:fixed ─────────────────────────────────────────
	// .hero-content has no z-index (removed from CSS so it forms no stacking
	// context). The logo's z-index:200 is therefore evaluated at the root
	// stacking context and beats the nav bar's z-index:100 directly.
	heroLogo.style.position      = 'fixed';
	heroLogo.style.left          = '50%';
	heroLogo.style.top           = startTop + 'px';
	heroLogo.style.transform     = 'translateX(-50%)';
	heroLogo.style.transformOrigin = 'top center';
	heroLogo.style.zIndex        = '200';
	// pointer-events:none — prevents the invisible scaled-away hit-test box
	// from blocking middle-clicks and other events on content below
	heroLogo.style.pointerEvents = 'none';
	// No CSS transition — opacity is driven frame-by-frame from scroll position
	heroLogo.style.transition    = 'none';
	// will-change: transform — promote to a persistent compositor layer
	// before scroll starts, so the per-frame transform updates in update()
	// don't churn between layered/non-layered states. Particularly helpful
	// on mobile where layer creation has measurable cost per frame.
	heroLogo.style.willChange    = 'transform';

	// Hero logo stays fully visible throughout the animation — it's the
	// single element that slides from hero position into the nav slot.
	// Set explicitly here (not just left to CSS default) so the opacity
	// state is one-shot rather than driven per-frame.
	heroLogo.style.opacity = '1';

	// Nav logo (.site-logo) stays invisible on the home page — the hero
	// logo itself fills that visual role at the end of the animation.
	// pointer-events starts disabled and becomes enabled once the title
	// has docked into the nav slot, so clicks on the nav-logo area then
	// land on the underlying <a href="/"> .site-logo for expected
	// "click logo to go home" behavior (hero-logo is a <div>, not a link).
	if (navLogo) {
		navLogo.style.opacity       = '0';
		navLogo.style.transition    = 'none';
		navLogo.style.pointerEvents = 'none';
	}
	if (slotBorder) {
		// Slot border is visible from the start — it marks the nav bar's
		// bottom edge and will be visible as the title slides through it
		slotBorder.style.opacity = '1';
	}

	function lerp(a, b, t) { return a + (b - a) * t; }

	// Ease function — swappable per-device via pickConfig() above.
	// Default desktop is cubic (t*t*t) which holds near 0 for most of the
	// scroll and snaps sharply at the end. Mobile default is quadratic (t*t)
	// for a gentler finish matched to mobile's shorter scroll runway.
	// Using a var (not a function declaration) so the resize handler can
	// swap it if the viewport crosses the mobile/desktop threshold.
	var ease = cfg.easeFn;

	var inNav   = false;
	var ticking = false;

	// Called once when scrollY >= phase1End — the hero title has fully
	// docked into the nav slot. Hero logo stays visible at this position
	// (no crossfade to a separate element); we just fade out the slot
	// border (the real nav bar bottom border visually takes over) and
	// enable pointer events on the underlying .site-logo so clicks on
	// the now-tiny title land on a real <a href="/">.
	//
	// SNAP TO FINAL TRANSFORM: on fast scroll (especially mobile flick-
	// scroll), the previous update() frame may have run with a scrollY
	// significantly less than phase1End — leaving the title at an
	// intermediate scale/position. The next frame fires with scrollY
	// past phase1End, enterNav() runs, inNav becomes true, and update()
	// stops touching the transform. The title visibly freezes mid-
	// animation. Setting the docked transform here guarantees the title
	// snaps to its final state regardless of how coarse the scroll
	// sampling was.
	function enterNav() {
		inNav = true;
		heroLogo.style.transform = 'translateX(-50%) translateY(' + (-phase1End) + 'px) scale(' + navScale + ')';
		if (navLogo) navLogo.style.pointerEvents = 'auto';
		if (slotBorder) slotBorder.style.opacity = '0';
	}

	// Called when scrollY drops back below phase1End — user scrolled up
	// past the docked state, so the title resumes its scale-and-slide
	// animation. Re-enable the slot border (it'll be visible as the
	// title passes back through it) and disable the nav-logo click
	// area (the docking point is no longer underneath).
	function exitNav() {
		inNav = false;
		heroLogo.style.transformOrigin = 'top center';
		if (navLogo) navLogo.style.pointerEvents = 'none';
		if (slotBorder) slotBorder.style.opacity = '1';
	}

	function update() {
		var scrollY = window.scrollY;

		if (scrollY >= phase1End) {
			if (!inNav) enterNav();
		} else {
			if (inNav) exitNav();
		}

		if (!inNav) {
			// Simulate in-flow scrolling using TRANSFORM, not `top`.
			// Why: `top` changes trigger layout (re-flow) every scroll
			// frame on mobile — the main cause of jitter on Android
			// Chrome. translateY() is composited (GPU layer), so it
			// updates without re-flow. Same visual result, smoother.
			//
			// Composition note: transforms apply right-to-left. So
			// `scale(S)` runs first (sizes the element), then
			// `translateY(Y)` shifts it in viewport pixels (Y is in
			// CSS pixels regardless of scale), then `translateX(-50%)`
			// centers horizontally based on the post-scale width.
			// Net result identical to the previous top-based approach.
			//
			// `top` itself stays at startTop (set once at setup) — no
			// per-frame layout cost.

			// p: scroll progress from 0 (page top) to 1 (title at nav position)
			var p  = Math.min(1, Math.max(0, scrollY / phase1End));
			var ep = ease(p);

			heroLogo.style.transform = 'translateX(-50%) translateY(' + (-scrollY) + 'px) scale(' + lerp(1, navScale, ep) + ')';

			// (letter-spacing animation was removed 2026-04-22 to eliminate
			//  per-frame LAYOUT work on mobile. Changing letter-spacing per
			//  frame triggers text re-flow inside the title element — the
			//  main remaining source of jitter on Android Chrome after the
			//  top→translateY refactor. Trade-off: at the docked position
			//  the title's letter-spacing is ~0.5px wider per gap than the
			//  interior pages' static nav logo (hero CSS is 0.15em, nav is
			//  0.12em). Small enough to not register visually in practice.
			//  If needed later, re-animate letter-spacing only during a
			//  specific sub-range of the scroll rather than every frame.)

			// (No opacity work needed in this block — hero logo stays fully
			//  opaque throughout the scroll, sliding under the nav slot border
			//  which has z-index 201 while the logo has z-index 200.)

			// ── Scroll hint ──────────────────────────────────────────────────────
			// Stays fully visible until 35% scroll, then dissolves by 65%.
			// Slower fade feels more considered than the immediate flash-out.
			if (scrollHint) {
				var hp = Math.max(0, Math.min(1, (p - 0.35) / 0.30));
				scrollHint.style.opacity = String(1 - hp);
			}
		}

		ticking = false;
	}

	window.addEventListener('scroll', function () {
		if (!ticking) { requestAnimationFrame(update); ticking = true; }
	}, { passive: true });

	// Unified resize handler — recalculates everything position-related on
	// any viewport change, and re-picks cfg in case the user crossed the
	// mobile/desktop threshold (e.g., device rotation on a tablet). The
	// earlier "if mobile, tear down state" branch was removed when we
	// enabled the animation on mobile — both form factors now run it.
	//
	// Width-only gate: mobile browsers fire resize events constantly during
	// the address-bar dance (Firefox Android especially), where only the
	// height changes. Running the full recalc + transform reset on those
	// events caused a one-frame flash where the title rendered at scale 1
	// without translateX(-50%) — visible as "title becomes huge and shoved
	// right" on slow scroll-up. Skipping height-only resizes eliminates the
	// flash entirely; address-bar dance only changes height, never width,
	// so this is safe for that case while still catching real resizes
	// (orientation change, window resize, devtools open) which all do
	// change width.
	var lastResizeWidth = window.innerWidth;
	window.addEventListener('resize', function () {
		if (window.innerWidth === lastResizeWidth) {
			// Height-only change (mobile address-bar dance). Just re-run
			// update() to re-apply the current scroll position transform —
			// no measurement work, no transform clear, no flash.
			if (!ticking) { requestAnimationFrame(update); ticking = true; }
			return;
		}
		lastResizeWidth = window.innerWidth;

		// Re-pick per-device config. If the threshold was crossed, `cfg`
		// swaps; otherwise this is a cheap no-op.
		cfg  = pickConfig();
		ease = cfg.easeFn;

		// Read fontSize directly — getComputedStyle returns the COMPUTED
		// CSS value, which is independent of any transforms applied to
		// the element. The previous `heroLogo.style.transform = ''` clear
		// was unnecessary AND was the source of the address-bar-flash bug
		// (one frame of cleared transform = title at scale 1, no centering).
		heroFontPx = parseFloat(getComputedStyle(heroLogo).fontSize);

		// Spacer's bounding rect tracks the logo's intended document position
		// across viewport width changes — this is why we inserted the spacer.
		var spRect = spacer.getBoundingClientRect();
		startTop   = spRect.top + window.scrollY;
		navScale   = navFontPx / heroFontPx;
		phase1End  = (startTop - navLogoTop) * cfg.phase1Multiplier;
		// (letter-spacing recomputation removed — animation no longer runs)

		// update() now uses transform: translateY(-scrollY) for scroll
		// tracking instead of style.top, so we need to update the base
		// `top` here when startTop changes (orientation change, real
		// viewport resize). Final viewport position = top + translateY
		// = startTop + (-scrollY) = startTop - scrollY, which matches
		// the previous top-based formula exactly.
		heroLogo.style.top = startTop + 'px';

		inNav = false;
		heroLogo.style.opacity         = '1';
		heroLogo.style.transformOrigin = 'top center';
		if (navLogo) { navLogo.style.opacity = '0'; navLogo.style.pointerEvents = 'none'; }
		if (slotBorder) slotBorder.style.opacity = '1';

		if (!ticking) { requestAnimationFrame(update); ticking = true; }
	}, { passive: true });

	// Run once on load in case the page restores to a scrolled position
	update();
}());
</script>
